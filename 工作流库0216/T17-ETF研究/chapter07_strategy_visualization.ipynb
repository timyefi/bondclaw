    "## 6. Stock ETF Analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def generate_stock_etf_tracking_index_table(df: pd.DataFrame,\n",
    "                                            nav_data: pd.DataFrame,\n",
    "                                            unit_data: pd.DataFrame,\n",
    "                                            start_date: str = None,\n",
    "                                            end_date: str = None) -> pd.DataFrame:\n",
    "    \"\"\"Generate stock ETF tracking index analysis table\n",
    "    \n",
    "    Args:\n",
    "        df: ETF base info DataFrame\n",
    "        nav_data: NAV data\n",
    "        unit_data: Unit data\n",
    "        start_date: Start date\n",
    "        end_date: End date\n",
    "        \n",
    "    Returns:\n",
    "        Analysis results DataFrame\n",
    "    \"\"\"\n",
    "    # Filter stock ETFs\n",
    "    stock_df = df[df['INVEST_TYPE_FIRST'] == 'stock'].copy()\n",
    "    \n",
    "    if stock_df.empty:\n",
    "        return pd.DataFrame()\n",
    "    \n",
    "    # Group by tracking index\n",
    "    results = []\n",
    "    \n",
    "    for index_name in stock_df['TRACKING_INDEX_NAME'].unique():\n",
    "        if pd.isna(index_name):\n",
    "            continue\n",
    "            \n",
    "        index_df = stock_df[stock_df['TRACKING_INDEX_NAME'] == index_name]\n",
    "        \n",
    "        metrics = calculate_strategy_metrics(\n",
    "            index_df, nav_data, unit_data, start_date, end_date\n",
    "        )\n",
    "        \n",
    "        if metrics:\n",
    "            results.append({\n",
    "                'Index Type': index_name,\n",
    "                'Fund Count': metrics['fund_count'],\n",
    "                'Total Size': f\"{index_df['UNIT_TOTAL'].sum() / 1e8:.2f}B\",\n",
    "                'Annual Return': f\"{metrics['annual_return']:.2f}%\",\n",
    "                'Volatility': f\"{metrics['volatility']:.2f}%\",\n",
    "                'Max Drawdown': f\"{metrics['max_drawdown']:.2f}%\"\n",
    "            })\n",
    "    \n",
    "    return pd.DataFrame(results)\n",
    "\n",
    "print(\"Stock ETF analysis function defined\")"
   ]
  },
