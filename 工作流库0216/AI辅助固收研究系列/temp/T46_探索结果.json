  "core_functionality": {
    "features": [
      {
        "name": "精细目标期限粒度",
        "description": "从18个标准点提升到0.01年精度（约3000个点）"
      },
      {
        "name": "针对性目标期限",
        "description": "聚焦7个关键期限点"
      },
      {
        "name": "数据结构优化",
        "description": "按目标期限拆分DataFrame，便于分别存储和处理"
      }
    ],
    "algorithms": [
      {
        "name": "Hermite插值",
        "description": "中债插值公式，用于计算非标准期限点的收益率",
        "formula": "h00*y1 + h10*(x2-x1)*d1 + h01*y2 + h11*(x2-x1)*d2"
      },
      {
        "name": "标准化收益率计算",
        "description": "计算标准化收益率",
        "formula": "标准化收益率 = 中债行权估值 + (目标期限收益率 - 原期限收益率)"
      }
    ]
  },
  "data_flow": {
