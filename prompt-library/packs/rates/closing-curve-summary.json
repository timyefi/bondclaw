{
  "id": "rates-closing-curve-summary-v1",
  "role": "rates",
  "workflow": "closing-curve-summary",
  "variant": "default",
  "required_skills": [
    "research-writing"
  ],
  "input_schema": {
    "type": "object",
    "required": [
      "date",
      "curve_moves",
      "end_of_day_view"
    ],
    "properties": {
      "date": { "type": "string" },
      "curve_moves": {
        "type": "array",
        "items": { "type": "string" }
      },
      "end_of_day_view": { "type": "string" }
    }
  },
  "prompt_template": "根据收盘时点的曲线变化生成简短总结，说明当天曲线如何演绎、哪些期限最值得关注、明天需要盯什么。先给结论，再给曲线变化，再给后续关注。",
  "output_format": "markdown",
  "sample_case": {
    "date": "2026-04-10",
    "curve_moves": [
      "5Y收益率下行",
      "10Y波动收窄"
    ],
    "end_of_day_view": "长端支撑仍在"
  },
  "qa_checklist": [
    "是否总结曲线变化",
    "是否指出关注期限",
    "是否说明次日跟踪"
  ]
}
