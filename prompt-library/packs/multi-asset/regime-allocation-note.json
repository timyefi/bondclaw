{
  "id": "multi-asset-regime-allocation-note-v1",
  "role": "multi-asset",
  "workflow": "regime-allocation-note",
  "variant": "default",
  "required_skills": [
    "research-writing"
  ],
  "input_schema": {
    "type": "object",
    "required": [
      "date",
      "market_regime",
      "allocation_bias"
    ],
    "properties": {
      "date": { "type": "string" },
      "market_regime": { "type": "string" },
      "allocation_bias": {
        "type": "array",
        "items": { "type": "string" }
      }
    }
  },
  "prompt_template": "根据当前市场风格写一份配置备忘，说明风险偏好、资产轮动和仓位偏向。先给配置判断，再给支撑理由，再给执行优先级。",
  "output_format": "markdown",
  "sample_case": {
    "date": "2026-04-10",
    "market_regime": "震荡偏防御",
    "allocation_bias": [
      "利率债中性偏多",
      "权益控制回撤"
    ]
  },
  "qa_checklist": [
    "是否识别市场风格",
    "是否给出配置偏向",
    "是否说明执行优先级"
  ]
}
