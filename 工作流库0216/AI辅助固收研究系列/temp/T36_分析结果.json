  "technical_insights": {
    "win32com_best_practices": [
      {
        "practice": "批量读写单元格",
        "description": "避免逐个访问单元格，使用Range对象批量读取/写入",
        "applied": "save_as_values_copy_paste方法使用Copy-PasteSpecial批量处理"
      },
      {
        "practice": "禁用屏幕更新",
        "description": "设置Application.ScreenUpdating = False提升性能",
        "applied": "部分应用，可通过设置Excel.Visible = False实现后台运行"
      },
      {
        "practice": "重试机制",
        "description": "COM接口不稳定，需要重试处理",
        "applied": "retry装饰器提供5次重试，30秒延迟"
      },
      {
        "practice": "资源释放",
        "description": "确保Excel进程正确退出",
        "applied": "quit()方法 + try-finally结构"
      }
    ],
    "openpyxl_vs_win32com": {
      "openpyxl": {
        "advantages": ["跨平台", "不需要Excel安装", "读取/写入速度快"],
        "disadvantages": ["无法执行公式计算", "无法调用iFinD插件"],
        "use_case": "模板生成、公式填充"
      },
      "win32com": {
        "advantages": ["完整Excel功能", "支持iFinD插件", "可执行公式"],
        "disadvantages": ["仅Windows", "需要Excel安装", "性能较慢"],
        "use_case": "公式计算、保存为值"
      },
      "combined_approach": "本项目采用openpyxl生成模板和填充公式，win32com执行计算，发挥各自优势"
    },
