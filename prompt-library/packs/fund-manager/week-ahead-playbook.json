{
  "id": "fund-manager-week-ahead-playbook-v1",
  "role": "fund-manager",
  "workflow": "week-ahead-playbook",
  "variant": "default",
  "required_skills": [
    "research-writing"
  ],
  "input_schema": {
    "type": "object",
    "required": [
      "week_start",
      "portfolio_priorities",
      "risk_items"
    ],
    "properties": {
      "week_start": { "type": "string" },
      "portfolio_priorities": {
        "type": "array",
        "items": { "type": "string" }
      },
      "risk_items": {
        "type": "array",
        "items": { "type": "string" }
      }
    }
  },
  "prompt_template": "基于输入的周度起点、组合优先项和风险项，生成一份周前交易和研究播放单。要求包含本周重点、组合动作、观察信号、风控提醒和周内复盘节点，保持研报写作风格。",
  "output_format": "markdown",
  "sample_case": {
    "week_start": "2026-04-13",
    "portfolio_priorities": ["久期控制", "信用分层", "现金管理"],
    "risk_items": ["政策变化", "流动性收缩"]
  },
  "qa_checklist": [
    "本周重点是否明确",
    "组合动作是否可执行",
    "风控提醒是否覆盖关键风险",
    "是否适合周会直接使用"
  ]
}
