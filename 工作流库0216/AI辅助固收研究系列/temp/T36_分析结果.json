    "core_components": {
      "ExcelCOMApp": {
        "description": "Excel COM操作封装类",
        "methods": {
          "open_workbook": "打开Excel工作簿，带重试机制",
          "calculate_worksheet": "执行工作表公式计算",
          "save_as_values_copy_paste": "Copy-Paste方式保存为值（性能好）",
