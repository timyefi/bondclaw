# 企业预警通地方化债数据爬虫环境变量配置
# 复制此文件为 .env 并填写实际值

# ================================
# 认证配置（必填）
# ================================
# Cookie认证信息 - 从浏览器开发者工具中获取
QYYJT_COOKIE=

# 用户ID（可选）
QYYJT_USER_ID=

# ================================
# API配置（可选）
# ================================
QYYJT_BASE_URL=https://www.qyyjt.cn
QYYJT_API_URL=https://www.qyyjt.cn/getData.action
QYYJT_DETAIL_API_URL=https://www.qyyjt.cn/finchinaAPP/newsDetail/getNewsContent.action

# ================================
# 爬虫运行配置（可选）
# ================================
# 请求延迟（秒）
QYYJT_CRAWL_DELAY=3

# 最大重试次数
QYYJT_MAX_RETRIES=5

# 请求超时时间（秒）
QYYJT_TIMEOUT=15

# 最大爬取页数
QYYJT_MAX_PAGES=300

# 是否增量爬取
QYYJT_INCREMENTAL=true

# ================================
# Playwright配置（可选）
# ================================
# 无头模式
QYYJT_HEADLESS=true

# ================================
# 初始skipParam（可选）
# ================================
QYYJT_INITIAL_SKIP_PARAM=
