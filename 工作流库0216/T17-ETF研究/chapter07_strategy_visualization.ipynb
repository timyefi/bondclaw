   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Strategy Metrics Calculator"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def calculate_strategy_metrics(strategy_df: pd.DataFrame, \n",
    "                              nav_data: pd.DataFrame,\n",
    "                              unit_data: pd.DataFrame,\n",
    "                              start_date: str,\n",
    "                              end_date: str) -> dict:\n",
    "    \"\"\"Calculate comprehensive strategy metrics\n",
    "    \n",
    "    Args:\n",
    "        strategy_df: Strategy definition DataFrame\n",
    "        nav_data: NAV data DataFrame\n",
    "        unit_data: Unit data DataFrame\n",
    "        start_date: Start date\n",
    "        end_date: End date\n",
    "        \n",
    "    Returns:\n",
    "        Metrics dictionary\n",
    "    \"\"\"\n",
    "    try:\n",
    "        if len(strategy_df) == 0:\n",
    "            return None\n",
    "        \n",
    "        # Get strategy name\n",
    "        if 'TRACKING_INDEX_NAME' in strategy_df.columns:\n",
    "            strategy_name = strategy_df['TRACKING_INDEX_NAME'].iloc[0]\n",
    "        else:\n",
    "            strategy_name = 'Unknown Strategy'\n",
    "        \n",
    "        # Get fund codes\n",
    "        fund_codes = strategy_df['TRADE_CODE'].tolist()\n",
    "        \n",
    "        # Filter NAV data\n",
    "        strategy_nav = nav_data[nav_data['TRADE_CODE'].isin(fund_codes)].copy()\n",
    "        strategy_nav['DT'] = pd.to_datetime(strategy_nav['DT'])\n",
    "        \n",
    "        start_date = pd.to_datetime(start_date)\n",
    "        end_date = pd.to_datetime(end_date)\n",
    "        \n",
    "        strategy_nav = strategy_nav[\n",
    "            (strategy_nav['DT'] >= start_date) & \n",
    "            (strategy_nav['DT'] <= end_date)\n",
    "        ]\n",
    "        \n",
    "        if len(strategy_nav) == 0:\n",
    "            return None\n",
    "        \n",
    "        # Find valid funds\n",
    "        valid_funds = []\n",
    "        for code in fund_codes:\n",
    "            fund_data = strategy_nav[strategy_nav['TRADE_CODE'] == code]\n",
    "            if len(fund_data) >= 2:\n",
    "                first_nav = fund_data.iloc[0]['NAV_ADJ']\n",
    "                last_nav = fund_data.iloc[-1]['NAV_ADJ']\n",
    "                if pd.notna(first_nav) and first_nav > 0 and pd.notna(last_nav):\n",
    "                    valid_funds.append(code)\n",
    "        \n",
    "        if len(valid_funds) == 0:\n",
    "            return None\n",
    "        \n",
    "        # Calculate average NAV\n",
    "        strategy_nav = strategy_nav[strategy_nav['TRADE_CODE'].isin(valid_funds)]\n",
    "        nav_pivot = strategy_nav.pivot(index='DT', columns='TRADE_CODE', values='NAV_ADJ')\n",
    "        nav_pivot = nav_pivot.ffill()\n",
    "        \n",
    "        daily_nav = nav_pivot.mean(axis=1).sort_index()\n",
    "        \n",
    "        if len(daily_nav) < 2:\n",
    "            return None\n",
    "        \n",
    "        # Calculate returns\n",
    "        returns = daily_nav.pct_change().dropna()\n",
    "        \n",
    "        # Annual return\n",
    "        total_return = (daily_nav.iloc[-1] / daily_nav.iloc[0]) - 1\n",
    "        days = (daily_nav.index[-1] - daily_nav.index[0]).days\n",
    "        annual_return = (1 + total_return) ** (365 / days) - 1 if days > 0 else 0\n",
    "        \n",
    "        # Volatility\n",
    "        volatility = returns.std() * np.sqrt(252)\n",
    "        \n",
    "        # Max drawdown\n",
    "        max_drawdown = 0\n",
    "        peak = daily_nav.iloc[0]\n",
    "        for nav in daily_nav:\n",
    "            if nav > peak:\n",
    "                peak = nav\n",
    "            drawdown = (peak - nav) / peak\n",
    "            if drawdown > max_drawdown:\n",
    "                max_drawdown = drawdown\n",
    "        \n",
    "        # Size change\n",
    "        strategy_unit = unit_data[unit_data['TRADE_CODE'].isin(valid_funds)].copy()\n",
    "        strategy_unit['DT'] = pd.to_datetime(strategy_unit['DT'])\n",
    "        strategy_unit = strategy_unit[\n",
    "            (strategy_unit['DT'] >= start_date) & \n",
    "            (strategy_unit['DT'] <= end_date) &\n",
    "            (strategy_unit['UNIT_ALL'] > 0)\n",
    "        ]\n",
    "        \n",
    "        if len(strategy_unit) > 0:\n",
    "            start_units = strategy_unit.groupby('TRADE_CODE')['UNIT_ALL'].first().sum()\n",
    "            end_units = strategy_unit.groupby('TRADE_CODE')['UNIT_ALL'].last().sum()\n",
    "            size_change_abs = (end_units - start_units) / 1e8\n",
    "            size_change_pct = (end_units - start_units) / start_units * 100 if start_units > 0 else 0\n",
    "        else:\n",
    "            size_change_abs = 0\n",
    "            size_change_pct = 0\n",
    "        \n",
    "        return {\n",
    "            'strategy_name': strategy_name,\n",
    "            'annual_return': annual_return * 100,\n",
    "            'volatility': volatility * 100,\n",
    "            'max_drawdown': max_drawdown * 100,\n",
    "            'size_change_abs': size_change_abs,\n",
    "            'size_change_pct': round(size_change_pct, 1),\n",
    "            'fund_count': len(valid_funds)\n",
    "        }\n",
    "        \n",
    "    except Exception as e:\n",
    "        logger.error(f\"Error calculating strategy metrics: {str(e)}\")\n",
    "        return None\n",
    "\n",
    "print(\"Strategy metrics calculator defined\")"
   ]
  },
