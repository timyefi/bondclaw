  "key_insights": {
    "technical_insights": [
      {
        "title": "双API数据源互补架构",
        "description": "Wind API擅长债券到期总量数据，iFinD API擅长单只债券详情数据，两者互补形成完整的一级市场数据视图",
        "application": "可扩展到其他需要多数据源融合的场景"
      },
      {
        "title": "动态列名转换技巧",
        "description": "通过中英文列名临时转换，解决MySQL中文列名在SQL语句中的兼容性问题",
        "code_pattern": "change_column_names(table, mapping, to_english=True) -> 数据操作 -> change_column_names(table, mapping, to_english=False)"
      },
      {
        "title": "UPSERT模式避免重复",
        "description": "使用INSERT ... ON DUPLICATE KEY UPDATE实现幂等数据插入",
        "sql_template": "INSERT INTO table (...) VALUES (...) ON DUPLICATE KEY UPDATE col=VALUES(col)"
      },
      {
        "title": "日期驱动增量采集",
        "description": "先查询已有日期，跳过已采集日期，实现增量数据采集",
        "efficiency": "避免重复采集，减少API调用次数"
      },
      {
        "title": "城投债单独统计策略",
        "description": "同一债券类型（企业债、公司债等）分两次调用，conceptbond参数区分是否城投",
        "business_value": "满足城投债专项分析需求"
      }
    ],
    "business_insights": [
      {
        "title": "一级市场前瞻性数据",
