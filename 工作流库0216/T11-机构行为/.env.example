# T11 - 机构行为分析环境变量配置示例
# 复制此文件为 .env 并填入实际值

# 数据目录
DATA_DIR=/data/项目/2025/机构行为

# 输出目录
OUTPUT_DIR=./output
CHARTS_DIR=./charts
REPORT_DIR=./report

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_username
DB_PASSWORD=your_password
DB_NAME=bond_market

# 数据文件
REPO_DATA_FILE=分机构日资金流向分析（质押）20250514-20250613-日度.xlsx
BOND_DATA_FILE=现券成交分机构统计20250601-20250710-日度.xlsx

# 分析参数
ANALYSIS_SPLIT_DATE=2025-05-25
MIN_HOLDING_VALUE=10000000
TOP_INSTITUTIONS=20
TRACKING_PERIOD=30
