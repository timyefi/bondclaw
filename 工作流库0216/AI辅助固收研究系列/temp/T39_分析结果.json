    ]
  },

  "refactoring_comparison": {
    "before": {
      "issues": [
        "硬编码数据库密码和API凭证",
        "全局变量滥用",
        "异常处理不完善(递归tryres有风险)",
        "缺乏日志输出",
        "代码结构扁平，缺乏模块化",
        "重试逻辑简单，无指数退避"
      ]
    },
    "after": {
      "improvements": [
        "使用环境变量管理敏感信息",
        "dataclass配置类封装参数",
        "面向对象设计，职责分离",
        "完善的异常处理和重试机制",
        "标准化日志输出",
        "模块化Notebook结构(7个章节)",
        "指数退避重试策略",
        "令牌缓存和自动刷新机制"
      ]
    }
  },

  "key_insights": [
    {
      "category": "数据采集",
      "insight": "采用令牌缓存机制避免频繁登录，2小时有效期自动检测刷新",
      "application": "减少API调用次数，提高采集效率"
    },
    {
      "category": "错误处理",
      "insight": "指数退避重试(1s, 2s, 3s, 4s, 5s)比固定间隔更有效",
      "application": "避免对API服务造成压力，提高成功率"
    },
    {
      "category": "流动性分析",
      "insight": "多维度加权评分(频率30%+成交30%+波动20%+收益率20%)更能反映真实流动性",
      "application": "为投资决策提供量化依据"
    },
    {
      "category": "配置管理",
      "insight": "dataclass + 环境变量组合实现安全且灵活的配置管理",
      "application": "代码可安全共享，部署灵活"
    },
    {
      "category": "增量更新",
      "insight": "通过SQL子查询排除已存在日期实现增量采集",
      "application": "避免重复采集，节省时间和资源"
    }
  ],

