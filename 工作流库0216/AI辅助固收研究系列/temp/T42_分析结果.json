  "businessLogicAnalysis": {
    "coreConcepts": [
      {
        "concept": "变更类型",
        "values": ["退出", "市场化转型", "隐性债务清零"],
        "businessMeaning": {
          "退出": "城投融资平台完全退出政府融资职能，转型为市场化运作的国有企业",
          "市场化转型": "按市场化要求建立公司法人治理结构，按《公司法》、《公司章程》规定开展市场化融资",
          "隐性债务清零": "隐性债务已清零，退出融资平台监管范畴"
        }
      },
      {
        "concept": "变更原因",
        "values": ["市场化转型", "隐性债务清零"],
        "businessMeaning": {
          "市场化转型": "响应中央、省债务管理要求，理清政府与企业边界，防范化解债务风险",
          "隐性债务清零": "实现隐性债务和融资平台双清零"
        }
      },
      {
        "concept": "发布主体",
        "mapping": {
          "1": "官方披露（政府或监管部门披露）",
          "2": "企业披露（企业主动披露转型信息）",
          "0": "其他",
          "3": "其他"
        },
        "businessImpact": "官方披露权威性更高，企业披露可能存在信息滞后"
      },
      {
        "concept": "主体评级",
        "values": ["AAA", "AA+", "AA", "AA-", "A"],
        "conditionalRule": "仅发债企业(issueBond='是')有评级信息"
      }
    ],
    "dataValidationRules": [
      {
        "rule": "必填字段检查",
        "fields": ["公司名称", "公司代码", "区域名称", "区域代码", "发布日期", "变更类型", "变更原因", "发布主体", "唯一标识", "省份", "城市"],
        "criticality": "高"
      },
      {
        "rule": "条件字段检查",
        "conditions": [
          "issueBond='是' -> subjectRating必须有值",
          "issueBond='是' -> bondStockSize必须有值"
        ],
        "criticality": "中"
      },
      {
        "rule": "一致性规则",
        "conditions": [
          "changeType='退出' -> changeReason一般为'市场化转型'",
          "issueBond='否' -> subjectRating应为null",
          "issueBond='否' -> bondStockSize应为null"
        ],
        "criticality": "中"
      },
      {
        "rule": "日期格式",
        "format": "YYYY-MM-DD",
        "criticality": "高"
      }
    ],
