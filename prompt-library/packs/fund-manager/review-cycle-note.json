{
  "id": "fund-manager-review-cycle-note-v1",
  "role": "fund-manager",
  "workflow": "review-cycle-note",
  "variant": "default",
  "required_skills": [
    "research-writing"
  ],
  "input_schema": {
    "type": "object",
    "required": [
      "date",
      "review_cycle",
      "constraint_flags"
    ],
    "properties": {
      "date": { "type": "string" },
      "review_cycle": { "type": "string" },
      "constraint_flags": { "type": "array", "items": { "type": "string" } }
    }
  },
  "prompt_template": "基于输入日期、复盘周期和约束信号，生成一份复盘周期说明。要求写清本周期核心变化、约束变化、下一周期重点和需要同步的动作，全文使用研报写作风格。",
  "output_format": "markdown",
  "sample_case": {
    "date": "2026-04-11",
    "review_cycle": "月度复盘",
    "constraint_flags": ["回撤抬升", "流动性偏紧"]
  },
  "qa_checklist": [
    "核心变化是否清楚",
    "约束变化是否明确",
    "下一周期重点是否具体",
    "是否适合投委或晨会使用"
  ]
}
