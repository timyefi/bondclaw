  "core_functions": {
    "data_acquisition": [
      "get_curve_data(dt) - 获取中债曲线数据",
      "get_credit_bond_data(dt, ratings) - 获取信用债市场数据",
      "get_target_term_data() - 获取目标期限配置"
    ],
    "data_processing": [
      "clean_curve_data(df) - 清洗曲线数据",
      "clean_credit_bond_data(df) - 清洗信用债数据",
      "correct_city_invest_flag(df) - 修正是否城投标识"
    ],
    "core_algorithms": [
      "hermite_interpolation(x, x1, x2, y1, y2, d1, d2, precision) - 三次Hermite插值",
      "find_anchor_points(term_values, terms) - 查找插值锚点",
      "calculate_curve(data_curve, data_target) - 计算曲线收益率",
      "calculate_standardized_yield(data_main, data_curve) - 计算标准化收益率"
    ],
    "utilities": [
      "calculate_weighted_yield(df, group_cols) - 计算加权平均收益率",
      "get_date_range(start_date, end_date) - 获取日期范围内的交易日列表",
      "filter_by_term_difference(df, tolerance) - 过滤期限差异过大的数据",
      "adjust_10year_node(df) - 调整10年节点"
    ]
  },
  "key_design_decisions": [
    {
      "decision": "Hermite插值选择",
      "reason": "保持曲线光滑（导数连续），避免龙格现象"
    },
    {
      "decision": "4个锚点插值",
      "reason": "使用中心差分计算导数，提高精度"
    },
    {
      "decision": "债券余额加权",
      "reason": "反映市场真实情况"
    },
    {
      "decision": "期限差异容忍度设为2年",
