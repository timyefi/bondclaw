        "default_delay": "30秒",
        "error_handling": "捕获所有异常，延迟后重试"
      }
    },
    "sql_logic": {
      "bond_survival_conditions": {
        "起息日条件": "ths_interest_begin_date_bond < dt OR IS NULL OR = '0000-00-00'",
        "到期日条件": "ths_maturity_date_bond > dt OR IS NULL OR = '0000-00-00'",
        "退市日条件": "ths_delist_date_bond > dt OR IS NULL OR = '0000-00-00'",
        "发行失败排除": "ths_is_issuing_failure_bond != '是'"
      },
      "deduplication": {
        "credit": "排除temp_credit表中已存在的trade_code",
        "finance": "排除temp_finance表中已存在的trade_code",
        "abs": "无临时去重表"
      },
      "query_structure": "UNION ALL合并三种债券类型查询结果"
    },
    "ifind_formula": {
      "format": "=@thsiFinD(\"指标名\", trade_code单元格, dt单元格, [参数])",
      "indicators": [
        {
          "name": "ths_bond_balance_bond",
          "column": "C",
          "formula_pattern": "=@thsiFinD(\"ths_bond_balance_bond\",B{row},A{row})",
          "params": null
        },
        {
          "name": "ths_evaluate_yield_yy_bond",
          "column": "D",
          "formula_pattern": "=@thsiFinD(\"ths_evaluate_yield_yy_bond\",B{row},A{row})",
          "params": null
        },
        {
          "name": "ths_cb_market_implicit_rating_bond",
          "column": "E",
          "formula_pattern": "=@thsiFinD(\"ths_cb_market_implicit_rating_bond\",B{row},A{row})",
          "params": null
        },
        {
          "name": "ths_evaluate_yield_cb_bond_exercise",
          "column": "F",
          "formula_pattern": "=@thsiFinD(\"ths_evaluate_yield_cb_bond_exercise\",B{row},A{row},102)",
          "params": 102
        },
        {
          "name": "ths_evaluate_modified_dur_cb_bond_exercise",
          "column": "G",
          "formula_pattern": "=@thsiFinD(\"ths_evaluate_modified_dur_cb_bond_exercise\",B{row},A{row},102)",
          "params": 102
        }
      ]
    },
    "data_validation": {
      "rules": [
        {
          "type": "required_columns",
          "columns": ["dt", "trade_code", "ths_bond_balance_bond", "ths_evaluate_yield_yy_bond", "ths_cb_market_implicit_rating_bond"]
        },
        {
          "type": "null_check",
          "description": "检查所有列的空值数量"
