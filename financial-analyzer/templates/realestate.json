{
  "name": "房地产行业模板",
  "version": "1.0",
  "description": "适用于房地产行业的信用分析财务指标模板",
  "currency": "CNY",
  "base_template": "general",
  "indicators": {
    "偿债能力指标": {
      "流动比率": {
        "formula": "流动资产 / 流动负债",
        "unit": "倍",
        "industry_benchmark": {"强": "> 1.5", "中等": "1.0-1.5", "弱": "< 1.0"}
      },
      "速动比率": {
        "formula": "(流动资产 - 存货 - 预付款项) / 流动负债",
        "unit": "倍",
        "industry_benchmark": {"强": "> 0.8", "中等": "0.5-0.8", "弱": "< 0.5"}
      },
      "现金比率": {
        "formula": "(货币资金 + 受限货币资金) / 流动负债",
        "unit": "倍",
        "industry_benchmark": {"强": "> 0.3", "中等": "0.15-0.3", "弱": "< 0.15"}
      },
      "资产负债率": {
        "formula": "(总负债 - 预收款) / 总资产",
        "unit": "%",
        "industry_benchmark": {"强": "< 70%", "中等": "70%-80%", "弱": "> 80%"}
      },
      "剔除预收款的资产负债率": {
        "formula": "(总负债 - 预收款) / (总资产 - 预收款)",
        "unit": "%",
        "industry_benchmark": {"强": "< 70%", "中等": "70%-80%", "弱": "> 80%"}
      }
    },
    "有息债务指标": {
      "有息负债总额": {
        "formula": "短期借款 + 长期借款 + 应付债券 + 一年内到期非流动负债",
        "unit": "万元",
        "source": "资产负债表"
      },
      "有息负债率": {
        "formula": "有息负债 / 总资产",
        "unit": "%"
      },
      "净负债": {
        "formula": "有息负债 - 货币资金 - 受限货币资金",
        "unit": "万元"
      },
      "净负债率": {
        "formula": "净负债 / (存货 + 货币资金 + 其他)",
        "unit": "%",
        "industry_benchmark": {"强": "< 60%", "中等": "60%-100%", "弱": "> 100%"}
      }
    },
    "EBITDA相关指标": {
      "EBITDA": {
        "formula": "净利润 + 利息支出 + 所得税 + 折旧 + 摊销",
        "unit": "万元"
      },
      "利息保障倍数(ICR)": {
        "formula": "EBITDA / 利息支出",
        "unit": "倍",
        "industry_benchmark": {"强": "> 3.0", "中等": "1.5-3.0", "弱": "< 1.5"}
      },
      "净负债/EBITDA": {
        "formula": "净负债 / EBITDA",
        "unit": "倍",
        "industry_benchmark": {"强": "< 3.0", "中等": "3.0-5.0", "弱": "> 5.0"}
      }
    },
    "房地产特有指标": {
      "土地储备": {
        "formula": "存货中的土地储备",
        "unit": "万元"
      },
      "在建开发产品": {
        "formula": "存货 - 土地储备 - 已完工产品",
        "unit": "万元"
      },
      "预收账款": {
        "formula": "资产负债表中预收款项",
        "unit": "万元"
      },
      "合同负债": {
        "formula": "资产负债表中合同负债",
        "unit": "万元"
      },
      "待售货值": {
        "formula": "已完工产品 + 在建产品中可售部分",
        "unit": "万元"
      },
      "去化周期": {
        "formula": "待售货值 / 平均月销售",
        "unit": "月"
      },
      "受限资产比例": {
        "formula": "受限资产 / 总资产",
        "unit": "%"
      },
      "担保余额": {
        "formula": "对子公司/关联方的担保余额",
        "unit": "万元"
      }
    },
    "现金流指标": {
      "经营活动现金流": {
        "formula": "经营活动产生的现金流量净额",
        "unit": "万元"
      },
      "销售回款": {
        "formula": "销售商品、提供劳务收到的现金",
        "unit": "万元"
      },
      "回款率": {
        "formula": "销售回款 / 合同负债",
        "unit": "%"
      },
      "现金流/利息": {
        "formula": "经营活动现金流 / 利息支出",
        "unit": "倍"
      }
    },
    "盈利能力指标": {
      "营业收入": {
        "formula": "利润表 - 营业收入",
        "unit": "万元"
      },
      "净利润": {
        "formula": "利润表 - 净利润",
        "unit": "万元"
      },
      "毛利率": {
        "formula": "(营业收入 - 营业成本) / 营业收入",
        "unit": "%"
      },
      "净利率": {
        "formula": "净利润 / 营业收入",
        "unit": "%"
      },
      "ROE": {
        "formula": "净利润 / 所有者权益",
        "unit": "%"
      }
    },
    "增长能力指标": {
      "销售面积增长率": {
        "formula": "(本期销售面积 - 上期销售面积) / 上期销售面积",
        "unit": "%"
      },
      "土地储备倍数": {
        "formula": "土地储备 / 销售面积",
        "unit": "年"
      }
    }
  }
}
