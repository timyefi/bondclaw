{
  "id": "rates-funding-morning-note-v1",
  "role": "rates",
  "workflow": "funding-morning-note",
  "variant": "default",
  "required_skills": [
    "research-writing"
  ],
  "input_schema": {
    "type": "object",
    "required": [
      "date",
      "funding_view",
      "key_rates"
    ],
    "properties": {
      "date": { "type": "string" },
      "funding_view": { "type": "string" },
      "key_rates": { "type": "array", "items": { "type": "string" } }
    }
  },
  "prompt_template": "基于输入日期、资金面判断和关键利率，生成一份利率晨间提示。要求写清资金松紧、关键利率水平、盘前预期和交易提醒，保持研报写作风格。",
  "output_format": "markdown",
  "sample_case": {
    "date": "2026-04-11",
    "funding_view": "略紧",
    "key_rates": ["DR007", "1D", "7D"]
  },
  "qa_checklist": [
    "资金判断是否明确",
    "利率水平是否写清",
    "交易提醒是否具体",
    "是否适合晨会快速查看"
  ]
}
