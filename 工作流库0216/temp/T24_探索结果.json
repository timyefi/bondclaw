        "偏股型": "纯债溢价率 > 10%"
      },
      "premium_classification": {
        "双低": "收盘价 <= 110 且 转股溢价率 <= 20%",
        "低价高溢": "收盘价 <= 110 且 转股溢价率 > 20%",
        "高价低溢": "收盘价 > 110 且 转股溢价率 <= 20%",
        "双高": "收盘价 > 110 且 转股溢价率 > 20%",
        "普通型": "不满足以上四种分类"
      },
      "sample_adjustment_steps": [
