{
  "id": "trader-morning-execution-checklist-v1",
  "role": "trader",
  "workflow": "morning-execution-checklist",
  "variant": "default",
  "required_skills": [
    "research-writing"
  ],
  "input_schema": {
    "type": "object",
    "required": [
      "date",
      "inventory_snapshot",
      "market_risks"
    ],
    "properties": {
      "date": { "type": "string" },
      "inventory_snapshot": {
        "type": "array",
        "items": { "type": "string" }
      },
      "market_risks": {
        "type": "array",
        "items": { "type": "string" }
      }
    }
  },
  "prompt_template": "根据库存和市场风险生成早盘执行清单，优先列出需要先处理的头寸、对手方、报价和风控事项。输出必须短、准、可直接开工。",
  "output_format": "markdown",
  "sample_case": {
    "date": "2026-04-10",
    "inventory_snapshot": [
      "利率债久期偏长",
      "信用债余额较多"
    ],
    "market_risks": [
      "资金面波动",
      "尾盘成交放大"
    ]
  },
  "qa_checklist": [
    "是否列出优先处理项",
    "是否覆盖对手方和风控",
    "是否适合早盘直接执行"
  ]
}
