{
  "project_id": "T39",
  "project_name": "成交数据",
  "analysis_date": "2026-02-16",
  "status": "completed",

  "code_architecture": {
    "design_pattern": "面向对象 + 模块化设计",
    "config_management": "dataclass配置类 + 环境变量",
    "error_handling": "完善的异常处理和重试机制",
    "logging": "标准化日志输出(logging模块)",
    "database": "SQLAlchemy ORM + 原生SQL混合使用",
    "key_classes": [
      {
        "name": "RatingDogAuthenticator",
        "purpose": "API认证管理",
        "features": ["令牌缓存", "自动刷新", "过期检测"]
      },
      {
        "name": "TradeDataCollector",
        "purpose": "成交数据采集",
        "features": ["分页获取", "指数退避重试", "数据库存储"]
      },
      {
        "name": "LiquidityAnalyzer",
        "purpose": "流动性分析",
        "features": ["多维度指标计算", "综合评分模型", "流动性分类"]
      },
      {
        "name": "StructureAnalyzer",
        "purpose": "结构分析",
        "features": ["行业分布", "评级分布", "时间模式分析"]
      }
    ]
  },

  "data_flow_analysis": {
    "source": {
      "api": "评级狗API (ratingdog.cn)",
      "auth_endpoint": "https://auth.ratingdog.cn/api/TokenAuth/Authenticate",
      "data_endpoint": "https://host.ratingdog.cn/api/services/app/Bond/QueryTradedHistoricalOfFrontDeskTenants",
      "pagination": "每页最多150条记录"
    },
    "processing": {
      "steps": [
        "1. 从bond.marketinfo_abs获取待采集日期",
        "2. 调用认证API获取accessToken",
        "3. 分页调用成交数据API获取items[]",
        "4. 数据清洗：类型转换、异常值处理",
        "5. 数据存储：追加写入yq.cjqb表"
      ]
    },
    "output": {
      "tables": ["yq.cjqb (全部成交)", "yq.cj (中介成交)"],
      "fields": ["bondCode", "tradedDate", "tradedAmount", "tradedPrice", "tradedYield", "yyIndustry", "yyRating"]
    }
  },

  "liquidity_analysis_model": {
    "dimensions": [
      {
        "name": "交易频率",
        "weight": 0.3,
        "metrics": ["日均交易次数", "交易天数"],
        "calculation": "日交易次数/交易天数，归一化0-1"
      },
      {
        "name": "成交量",
        "weight": 0.3,
        "metrics": ["总成交金额", "平均成交金额", "变异系数"],
        "calculation": "总金额归一化0-1"
      },
      {
        "name": "价格稳定性",
        "weight": 0.2,
        "metrics": ["价格波动率", "收益率波动"],
        "calculation": "1 - (波动率/最大波动率)"
      },
      {
        "name": "收益率一致性",
        "weight": 0.2,
        "metrics": ["收益率范围", "收益率标准差"],
        "calculation": "1 - (收益率范围/最大范围)"
      }
    ],
    "classification": {
      "high": "评分 >= 70",
      "medium": "评分 >= 40",
      "low": "评分 < 40"
    },
    "output_metrics": [
      "liquidity_score (0-100综合评分)",
      "liquidity_class (高/中/低流动性)",
      "freq_score, volume_score, volatility_score, yield_score"
    ]
  },

  "structure_analysis_model": {
    "dimensions": [
      {
        "name": "行业分布",
        "field": "yyIndustry",
        "metrics": ["成交金额", "成交笔数", "债券数", "占比"]
      },
      {
        "name": "评级分布",
        "field": "yyRating",
        "metrics": ["成交金额", "成交笔数", "占比"],
        "sort_order": ["AAA", "AAA-", "AA+", "AA", "AA-", "A+", "A", "A-", "BBB+", "BBB", "BBB-", "BB+", "BB", "BB-", "B", "CCC", "CC", "C", "D"]
      },
      {
        "name": "时间模式",
        "analysis": ["每日交易统计", "周内交易模式", "趋势分析"]
      },
      {
        "name": "成交规模",
        "thresholds": {
          "small": "<100万",
          "medium": "100万-1000万",
          "large": "1000万-1亿",
          "xlarge": ">1亿"
        }
      }
    ]
  },

  "visualization_features": {
