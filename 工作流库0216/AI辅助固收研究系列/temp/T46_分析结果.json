  "algorithm_analysis": {
    "hermite_interpolation": {
      "type": "数值插值算法",
      "description": "中债曲线Hermite插值公式",
      "formula": {
        "basis_functions": {
          "h00": "2*t^3 - 3*t^2 + 1",
          "h10": "t^3 - 2*t^2 + t",
          "h01": "-2*t^3 + 3*t^2",
          "h11": "t^3 - t^2"
        },
        "result": "h00*y1 + h10*(x2-x1)*d1 + h01*y2 + h11*(x2-x1)*d2",
        "parameter_t": "t = (x - x1) / (x2 - x1)"
      },
      "inputs": [
        {"name": "x", "description": "待插值点（债券期限）"},
        {"name": "x1, x2", "description": "插值区间端点"},
        {"name": "y1, y2", "description": "区间端点函数值（收益率）"},
        {"name": "d1, d2", "description": "区间端点导数值"}
      ],
      "computational_complexity": "O(n) 对于n个待插值点",
      "accuracy": "C1连续，适合收益率曲线插值"
    },
    "standardized_yield_calculation": {
      "type": "收益率调整算法",
      "formula": "标准化收益率 = 中债行权估值 + (目标期限收益率 - 原期限收益率)",
      "economic_meaning": "将不同期限的债券收益率标准化到统一的目标期限，便于比较",
      "implementation": {
        "refactored": "calculate_standardized_yield()函数",
        "original": "第248-249行直接计算"
      }
    },
    "curve_matching": {
      "type": "数据匹配算法",
      "approach": "基于多键值的DataFrame join操作",
      "matching_keys": ["日期", "隐含评级", "是否城投", "期限"],
      "priority_order": [
        {"priority": 1, "curve_type": "公募否否曲线", "condition": "发行方式=公募"},
        {"priority": 2, "curve_type": "私募否否曲线", "condition": "发行方式=私募"},
        {"priority": 3, "curve_type": "公募永续曲线", "condition": "是否永续=是"},
        {"priority": 4, "curve_type": "完整曲线", "condition": "其他情况"}
      ]
    }
  },
