    "data_flow_analysis": {
      "maturity_data_flow": {
        "source": "Wind API",
        "steps": [
          "1. 初始化Wind连接 (w.start())",
          "2. 确定日期范围（未来7天）",
          "3. 查询数据库已有日期，跳过已采集日期",
          "4. 循环处理每个日期的27种债券类型",
          "5. 调用w.wset()获取原始数据",
          "6. 标记债券类型和城投属性",
          "7. 列名转换（中文→英文col_0,col_1...）",
          "8. 执行UPSERT入库",
          "9. 列名恢复（英文→中文）"
        ],
        "output_table": "债券到期",
        "api_calls_per_day": 27
      },
      "issue_data_flow": {
        "source": "iFinD API",
        "steps": [
          "1. 登录iFinD (THS_iFinDLogin)",
          "2. 确定日期范围（未来1-30天）",
          "3. 单次调用THS_DR()获取全部数据",
          "4. 列名重命名为标准字段名",
          "5. 列名转换（中文→英文）",
          "6. 执行数据入库",
          "7. 列名恢复（英文→中文）",
          "8. 执行去重SQL（临时表方式）"
        ],
        "output_table": "债券新发行1",
        "api_calls_per_run": 1
      }
    },
