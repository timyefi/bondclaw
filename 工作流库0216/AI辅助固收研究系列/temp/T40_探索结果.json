  "探索时间": "2026-02-16",
  "项目概述": {
    "功能描述": "区域基本面项目专注于分析不同区域的经济基本面,包括GDP增速、财政收入、产业结构、人口结构、投资情况等,为区域债投资和区域风险评估提供基本面数据支持",
    "核心功能": [
      "区域经济数据采集与处理",
      "综合财力计算",
      "经济活力与发展潜力评估",
      "区域综合评分与风险评级",
      "区域对比分析"
    ]
  },
  "数据源": {
    "主数据表": "bond.fiscal_region_city_county",
    "API接口": "企业预警通/评级狗 区域数据API",
    "关键字段": [
      "DT - 报告日期",
      "省 - 省份",
      "市 - 城市",
      "区县 - 区县",
      "地区级别 - 省级/地市级/区县级",
      "城投平台有息债务余额 - 城投债务数据",
      "城投债券余额 - 城投债券数据",
      "地方债务余额 - 地方债务数据"
    ]
  },
  "核心算法": {
    "综合评分公式": "综合评分 = 财政实力评分 * 0.4 + 经济活力评分 * 0.3 + 发展潜力评分 * 0.3",
    "风险评级标准": {
      "AAA": {"综合评分": ">=80", "负债率上限": "<1.0"},
      "AA+": {"综合评分": ">=70", "负债率上限": "<1.5"},
      "AA": {"综合评分": ">=60", "负债率上限": "<2.0"},
      "AA-": {"综合评分": ">=50", "负债率上限": "<3.0"},
      "A": {"综合评分": ">=40", "负债率上限": "无限制"},
      "BBB": {"综合评分": ">=30", "负债率上限": "无限制"},
      "BB": {"综合评分": "<30", "负债率上限": "无限制"}
    }
  },
  "配置参数": {
    "财政权重": {
      "general_budget": 0.7,
      "gov_fund": 0.3
    },
    "债务预警级别": {
      "debt_to_gdp": 0.6,
      "debt_to_fiscal": 2.0,
      "debt_growth": 0.2
    },
    "增长目标": {
      "high_growth": 8.0,
      "medium_growth": 6.0,
      "low_growth": 4.0
    },
    "城投债务估算系数": 2.0
  },
  "文件结构": {
    "主要文件": [
      {
        "文件名": "重构.ipynb",
