  "algorithm_analysis": {
    "hermite_interpolation": {
      "type": "三次Hermite插值",
      "mathematical_foundation": {
        "basis_functions": {
          "H1": {
            "formula": "1 - 3t^2 + 2t^3",
            "property": "在t=0时为1，t=1时为0，保证函数值在端点连续"
          },
          "H2": {
            "formula": "3t^2 - 2t^3",
            "property": "在t=0时为0，t=1时为1，保证函数值在端点连续"
          },
          "H3": {
            "formula": "t - 2t^2 + t^3",
            "property": "在t=0和t=1时为0，控制左侧导数影响"
          },
          "H4": {
            "formula": "-t^2 + t^3",
            "property": "在t=0和t=1时为0，控制右侧导数影响"
          }
        },
        "interpolation_formula": "y(x) = y1*H1(t) + y2*H2(t) + d1*H3(t) + d2*H4(t)",
        "normalization": "t = (x - x1) / (x2 - x1)"
      },
      "advantages": [
        "C1连续性（函数值和一阶导数均连续）",
        "避免龙格现象（Runge phenomenon）",
        "局部支持性（修改一个控制点只影响局部）",
        "数值稳定性好"
      ],
      "implementation_details": {
        "precision": 4,
        "input_handling": "支持标量和数组输入",
        "vectorization": "使用NumPy向量化运算"
      }
    },
    "derivative_calculation": {
      "method": "中心差分法",
      "formula": {
        "d1": "(y2 - y11) / (2 * (x2 - x11))",
        "d2": "(y22 - y1) / (2 * (x22 - x1))"
      },
      "accuracy_order": "二阶精度O(h^2)",
      "anchor_points": {
        "description": "使用4个锚点计算导数",
        "points": ["x11(左前锚点)", "x1(左锚点)", "x2(右锚点)", "x22(右后锚点)"],
        "purpose": "提高导数估计精度，避免边界效应"
      }
    },
    "anchor_point_finding": {
      "algorithm": "二分查找 + 向量化操作",
      "implementation": {
        "x1": "小于等于目标期限的最大标准期限",
        "x2": "大于等于目标期限的最小标准期限",
        "x11": "x1的前一个标准期限（用于计算d1）",
        "x22": "x2的后一个标准期限（用于计算d2）"
      },
      "edge_cases": {
        "below_minimum": "期限小于最小标准期限时直接匹配",
        "above_maximum": "期限大于最大标准期限时直接匹配",
        "exact_match": "期限恰好等于标准期限时直接取值"
      }
    },
    "standardized_yield_calculation": {
      "formula": "目标期限收益率 = 中债行权估值 + (目标期限曲线收益率 - 原期限曲线收益率)",
      "economic_meaning": "将不同期限债券的收益率调整到统一标准期限，便于比较",
      "assumptions": [
        "收益率曲线在目标期限和原期限之间大致平行移动",
        "信用利差在不同期限保持相对稳定"
      ]
    }
  },
