{
  "id": "credit-funding-access-note-v1",
  "role": "credit",
  "workflow": "funding-access-note",
  "variant": "default",
  "required_skills": [
    "research-writing"
  ],
  "input_schema": {
    "type": "object",
    "required": [
      "issuer",
      "date",
      "funding_signals"
    ],
    "properties": {
      "issuer": { "type": "string" },
      "date": { "type": "string" },
      "funding_signals": { "type": "array", "items": { "type": "string" } }
    }
  },
  "prompt_template": "针对输入发行人和融资信号，生成一份融资可得性观察笔记。要求拆解银行授信、债券融资、非标替代和再融资路径，并给出对信用利差和持仓策略的含义，全文保持研报写作风格。",
  "output_format": "markdown",
  "sample_case": {
    "issuer": "示例发行人",
    "date": "2026-04-11",
    "funding_signals": ["授信收紧", "债券发行推迟", "融资成本抬升"]
  },
  "qa_checklist": [
    "融资信号是否具体",
    "路径拆解是否完整",
    "对利差和持仓含义是否明确",
    "是否适合作为信用晨会材料"
  ]
}
