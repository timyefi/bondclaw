  "core_algorithms": {
    "wavelet_analysis": {
      "wavelet_type": "db2 (Daubechies 2)",
      "decomposition_method": "pywt.wavedec",
      "reconstruction_method": "pywt.waverec",
      "output_metrics": ["周期分位点", "趋势方向(1/-1/0)"]
    },
    "data_processing": {
      "outlier_handling": "IQR方法",
      "interpolation": "线性插值",
      "resampling": "月末重采样",
      "transformations": [
        "calculate_yoy_12ma (12月移动平均年同比)",
        "monthly_yoy_12ma (月同比12个月移动平均)",
        "highfreq_price_yoy (高频价格月均价年同比)"
      ]
