    "def fetch_bond_maturity_data_wind(dt_str, bond_types=BOND_TYPES):\n",
    "    \"\"\"\n",
    "    从Wind API获取债券到期数据\n",
    "    \n",
    "    Args:\n",
    "        dt_str: 日期字符串 (YYYY-MM-DD)\n",
    "        bond_types: 债券类型列表\n",
    "        \n",
    "    Returns:\n",
    "        汇总的数据DataFrame\n",
    "    \"\"\"\n",
    "    if not WIND_AVAILABLE:\n",
    "        print(\"Wind API不可用，无法获取数据\")\n",
    "        return None\n",
    "    \n",
    "    # 初始化Wind\n",
    "    w.start()\n",
    "    \n",
    "    all_data = []\n",
    "    table_name = '债券到期'\n",
    "    \n",
    "    for bond_type_code, bond_type_name, is_urban in bond_types:\n",
    "        # 构建conceptbond参数\n",
    "        if is_urban == '是':\n",
    "            conceptbond = 'urbaninvestmentbonds(wind)'\n",
    "        else:\n",
    "            conceptbond = 'default'\n",
    "        \n",
    "        # 调用Wind API\n",
    "        error_code, wsd_data = w.wset(\n",
    "            \"bondissuanceandmaturity\",\n",
    "            f\"startdate={dt_str};enddate={dt_str};frequency=day;maingrade=all;zxgrade=all;\"\n",
    "            f\"datetype=startdate;duedatetype=byactualpaymentdate;type=default;publishlimited=all;\"\n",
    "            f\"bondtype={bond_type_code};dealmarket=allmarkets;conceptbond={conceptbond};\"\n",
    "            f\"field=startdate,enddate,totalredemption\",\n",
    "            usedf=True\n",
    "        )\n",
    "        \n",
    "        if error_code == 0 and wsd_data is not None and not wsd_data.empty:\n",
    "            # 添加债券类型和城投标识\n",
    "            wsd_data['bondtype'] = bond_type_name\n",
    "            wsd_data['isurbaninvestmentbonds'] = is_urban\n",
    "            wsd_data.rename(columns={'startdate': 'dt'}, inplace=True)\n",
    "            if 'enddate' in wsd_data.columns:\n",
    "                wsd_data.drop(columns=['enddate'], inplace=True)\n",
    "            \n",
    "            all_data.append(wsd_data)\n",
    "            print(f\"  {bond_type_name}（城投:{is_urban}）: {len(wsd_data)}条\")\n",
    "    \n",
    "    if all_data:\n",
    "        return pd.concat(all_data, ignore_index=True)\n",
    "    return None\n",
    "\n",
    "\n",
    "def collect_bond_maturity_data(days_ahead=7):\n",
    "    \"\"\"\n",
    "    采集债券到期数据\n",
    "    \n",
    "    Args:\n",
    "        days_ahead: 获取未来几天的数据\n",
    "    \"\"\"\n",
    "    current_date = datetime.now()\n",
    "    end_date = current_date + timedelta(days=days_ahead)\n",
    "    dt0 = current_date.strftime('%Y-%m-%d')\n",
    "    dt1 = end_date.strftime('%Y-%m-%d')\n",
    "    \n",
    "    # 查询已有日期\n",
    "    query = f\"\"\"\n",
    "    SELECT DISTINCT dt\n",
    "    FROM yq.债券到期\n",
    "    WHERE dt >= '{dt0}'\n",
    "    \"\"\"\n",
    "    \n",
    "    try:\n",
    "        with sql_engine.begin() as connection:\n",
    "            dates = pd.read_sql(query, con=connection)\n",
    "        dates['dt'] = pd.to_datetime(dates['dt'])\n",
    "        existing_dates = set(dates['dt'].values)\n",
    "    except Exception as e:\n",
    "        print(f\"查询已有日期失败: {e}\")\n",
    "        existing_dates = set()\n",
    "    \n",
    "    print(f\"采集日期范围: {dt0} ~ {dt1}\")\n",
    "    print(f\"已有数据日期数: {len(existing_dates)}\")\n",
    "    \n",
    "    # 循环处理每个日期\n",
    "    for dt in pd.date_range(start=dt0, end=dt1):\n",
    "        if dt in existing_dates:\n",
    "            print(f\"跳过 {dt.strftime('%Y-%m-%d')} (已有数据)\")\n",
    "            continue\n",
    "        \n",
    "        dt_str = dt.strftime('%Y-%m-%d')\n",
    "        print(f\"\\n处理日期: {dt_str}\")\n",
    "        \n",
    "        # 获取数据\n",
    "        df = fetch_bond_maturity_data_wind(dt_str)\n",
    "        \n",
    "        if df is not None and not df.empty:\n",
    "            # 列名转换和入库\n",
    "            table_name = '债券到期'\n",
    "            column_mapping = generate_column_mapping(df.columns)\n",
    "            \n",
    "            change_column_names(table_name, column_mapping, sql_engine, to_english=True)\n",
    "            pro_data(df, table_name, sql_engine)\n",
    "            change_column_names(table_name, column_mapping, sql_engine, to_english=False)\n",
    "        else:\n",
    "            print(f\"  无数据\")\n",
    "\n",
    "print(\"债券到期数据采集函数定义完成\")"
   ]
  },
