      },
      {
        "文件名": "更新fiscal_region_city_county.txt",
        "类型": "SQL脚本",
        "描述": "数据库更新SQL脚本,用于修正债务数据"
      }
    ],
    "空目录": ["data/", "output/", "assets/"]
  },
  "Notebook结构": {
    "单元格总数": 33,
    "主要模块": [
      "环境配置(导入依赖)",
      "配置参数(数据库连接、区域配置)",
      "数据获取(数据库连接、数据读取)",
      "数据处理(数据清洗、债务数据修正)",
      "核心逻辑(综合财力计算、经济活力计算、区域综合评分、风险评级)",
      "执行与测试(主流程、结果验证、可视化输出)",
      "工具函数(可复用函数集合)"
    ]
  },
  "关键函数": {
    "数据获取": ["create_db_engine", "load_region_data"],
    "数据处理": ["clean_region_data", "correct_debt_data"],
    "核心计算": [
      "calculate_comprehensive_fiscal_power",
      "calculate_economic_vitality",
      "calculate_regional_score",
      "classify_regional_risk"
    ],
    "辅助函数": ["compare_regions", "get_region_identifier", "calculate_debt_ratios", "fill_missing_with_adjacent", "export_to_excel"],
    "主函数": ["run_regional_analysis", "validate_results"]
  },
  "债务数据修正逻辑": {
    "步骤1": "债务余额 < 债券余额 -> 用债券余额填充",
    "步骤2": "市本级数据修正 -> 等于下辖区县债务总和",
    "步骤3": "省市级数据修正 -> 等于下级区县债务总和",
    "步骤4": "缺失数据填充 -> 使用相邻日期数据或地方债务余额的2倍估算"
  },
