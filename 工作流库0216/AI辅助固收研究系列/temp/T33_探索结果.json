  "etl_process": {
    "steps": [
      {
        "step": 1,
        "name": "债券分类重建",
        "description": "清空并重建债券分类表，分类信用债、金融债、ABS"
      },
      {
        "step": 2,
        "name": "评级补全",
        "description": "从marketinfo_*表获取每个债券最新日期的隐含评级"
      },
      {
        "step": 3,
        "name": "市场数据插入",
        "description": "插入信用债、金融债、ABS的余额和久期数据到marketinfo3"
      },
      {
        "step": 4,
        "name": "久期补全",
        "description": "对久期缺失的记录，从基础信息表计算剩余年限（含永续债特殊处理）"
      },
      {
        "step": 5,
        "name": "隐含评级更新",
        "description": "更新marketinfo3表的隐含评级字段"
      },
      {
        "step": 6,
        "name": "规模统计汇总",
        "description": "执行14个汇总查询，按11种分类方式统计债券规模"
      }
    ],
    "estimated_runtime": "10-30分钟",
    "recommended_frequency": "每周执行一次"
  },
