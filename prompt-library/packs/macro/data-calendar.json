{
  "id": "macro-data-calendar-v1",
  "role": "macro",
  "workflow": "data-calendar",
  "variant": "default",
  "required_skills": [
    "research-writing"
  ],
  "input_schema": {
    "type": "object",
    "required": [
      "calendar_date",
      "data_points"
    ],
    "properties": {
      "calendar_date": { "type": "string" },
      "data_points": { "type": "array", "items": { "type": "string" } }
    }
  },
  "prompt_template": "基于输入日期和数据点，生成一份宏观数据日历。要求按照时间顺序列出数据名称、预期关注点、可能影响的资产方向和需要提前准备的问题，保持研报写作风格。",
  "output_format": "markdown",
  "sample_case": {
    "calendar_date": "2026-04-11",
    "data_points": ["社融", "通胀", "进出口"]
  },
  "qa_checklist": [
    "数据点是否完整",
    "时间顺序是否清楚",
    "资产影响是否写明",
    "是否适合盘前查看"
  ]
}
