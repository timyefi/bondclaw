  "project_description": {
    "summary": "债券新发行系统是一个综合性的债券一级市场数据采集和分析工具，主要功能包括债券到期数据采集（Wind API）和债券新发行数据采集（同花顺iFinD API）。",
    "core_functions": [
      "债券到期数据采集：从Wind API获取各种类型债券的发行和到期数据",
      "债券新发行分析：从同花顺iFinD API获取新发债券的详细信息",
      "数据存储与管理：将数据存储到MySQL数据库，支持动态列管理",
      "数据去重与清洗：自动识别和删除重复数据"
    ]
  },
