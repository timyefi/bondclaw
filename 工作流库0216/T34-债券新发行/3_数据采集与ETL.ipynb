    "def collect_bond_issue_data_ifind(days_start=1, days_end=30):\n",
    "    \"\"\"\n",
    "    从同花顺iFinD API获取债券新发行数据\n",
    "    \n",
    "    Args:\n",
    "        days_start: 开始日期偏移（相对于今天）\n",
    "        days_end: 结束日期偏移（相对于今天）\n",
    "    \"\"\"\n",
    "    if not IFIND_AVAILABLE:\n",
    "        print(\"iFinD API不可用，无法获取数据\")\n",
    "        return\n",
    "    \n",
    "    # 登录iFinD\n",
    "    if IFIND_USERNAME and IFIND_PASSWORD:\n",
    "        login_result = THS_iFinDLogin(IFIND_USERNAME, IFIND_PASSWORD)\n",
    "        print(f\"iFinD登录结果: {login_result}\")\n",
    "    else:\n",
    "        print(\"iFinD用户名或密码未配置\")\n",
    "        return\n",
    "    \n",
    "    # 计算日期范围\n",
    "    current_date = datetime.now()\n",
    "    start_date = current_date + timedelta(days=days_start)\n",
    "    end_date = current_date + timedelta(days=days_end)\n",
    "    dt0 = start_date.strftime('%Y%m%d')\n",
    "    dt1 = end_date.strftime('%Y%m%d')\n",
    "    \n",
    "    print(f\"采集日期范围: {start_date.strftime('%Y-%m-%d')} ~ {end_date.strftime('%Y-%m-%d')}\")\n",
    "    \n",
    "    # 调用iFinD API\n",
    "    df = THS_DR(\n",
    "        'p04524',\n",
    "        f'sdate={dt0};edate={dt1};zqlx={IFIND_BOND_TYPES};'\n",
    "        f'sclx=0;jglx=0;datetype=5;fxqx=0;ztpj=0;hy=0;qyxz=0;dq=0;gnfl=0',\n",
    "        'jydm:Y,jydm_mc:Y,p04524_f005:Y,p04524_f006:Y,p04524_f009:Y,p04524_f029:Y,p04524_f063:Y',\n",
    "        'format:dataframe'\n",
    "    )\n",
    "    \n",
    "    if df is None or df.data is None:\n",
    "        print(\"未获取到数据\")\n",
    "        return\n",
    "    \n",
    "    df = df.data\n",
    "    \n",
    "    if df.empty:\n",
    "        print(\"数据为空\")\n",
    "        return\n",
    "    \n",
    "    # 重命名列\n",
    "    df.columns = ['trade_code', 'sec_name', 'dt', 'planissueamount', 'bondterm', 'bondtype', 'isurbaninvestmentbonds']\n",
    "    \n",
    "    print(f\"获取数据: {len(df)}条\")\n",
    "    print(df.head())\n",
    "    \n",
    "    # 列名转换和入库\n",
    "    table_name = '债券新发行1'\n",
    "    column_mapping = generate_column_mapping(df.columns)\n",
    "    \n",
    "    change_column_names(table_name, column_mapping, sql_engine, to_english=True)\n",
    "    pro_data(df, table_name, sql_engine)\n",
    "    change_column_names(table_name, column_mapping, sql_engine, to_english=False)\n",
    "    \n",
    "    # 执行去重\n",
    "    deduplicate_bond_issue_data()\n",
    "\n",
    "\n",
    "def deduplicate_bond_issue_data():\n",
    "    \"\"\"\n",
    "    对债券新发行数据进行去重\n",
    "    \n",
    "    去重逻辑:\n",
    "    1. 债券名称唯一的记录保留\n",
    "    2. 债券名称重复的记录，保留非S开头的最小代码\n",
    "    \"\"\"\n",
    "    with sql_engine.begin() as connection:\n",
    "        connection.execute(text(\"\"\"\n",
    "        CREATE TEMPORARY TABLE temp_table AS\n",
    "        SELECT * FROM `债券新发行1`\n",
    "        WHERE sec_name IN (\n",
    "            SELECT sec_name\n",
    "            FROM `债券新发行1`\n",
    "            GROUP BY sec_name\n",
    "            HAVING COUNT(*) = 1\n",
    "        )\n",
    "        UNION\n",
    "        SELECT * FROM `债券新发行1`\n",
    "        WHERE trade_code IN (\n",
    "            SELECT MIN(trade_code)\n",
    "            FROM `债券新发行1`\n",
    "            WHERE trade_code NOT LIKE 'S%%'\n",
    "            GROUP BY sec_name\n",
    "            HAVING COUNT(*) > 1\n",
    "        );\n",
    "\n",
    "        DELETE FROM `债券新发行1`;\n",
    "\n",
    "        INSERT INTO `债券新发行1` SELECT * FROM temp_table;\n",
    "\n",
    "        DROP TEMPORARY TABLE temp_table;\n",
    "        \"\"\"))\n",
