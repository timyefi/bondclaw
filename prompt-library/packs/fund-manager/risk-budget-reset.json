{
  "id": "fund-manager-risk-budget-reset-v1",
  "role": "fund-manager",
  "workflow": "risk-budget-reset",
  "variant": "default",
  "required_skills": [
    "research-writing"
  ],
  "input_schema": {
    "type": "object",
    "required": [
      "date",
      "risk_budget_state",
      "constraint_flags"
    ],
    "properties": {
      "date": { "type": "string" },
      "risk_budget_state": { "type": "string" },
      "constraint_flags": { "type": "array", "items": { "type": "string" } }
    }
  },
  "prompt_template": "基于输入日期、风险预算状态和约束信号，生成一份风险预算重置说明。要求写清当前风险预算、约束变化、是否需要降风险或调结构，以及下一步核查清单，全文使用研报写作风格。",
  "output_format": "markdown",
  "sample_case": {
    "date": "2026-04-11",
    "risk_budget_state": "风险预算接近上限",
    "constraint_flags": ["回撤抬升", "久期超配"]
  },
  "qa_checklist": [
    "风险预算状态是否清楚",
    "约束变化是否明确",
    "动作建议是否具体",
    "是否适合投委或晨会使用"
  ]
}
