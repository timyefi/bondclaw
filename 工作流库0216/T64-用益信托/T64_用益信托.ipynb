   "source": [
    "# T64-用益信托\n",
    "\n",
    "本Notebook实现用益信托网数据采集功能，包括：\n",
    "- 标品信托数据采集\n",
    "- 文章内容解析\n",
    "- 数据存储到MySQL数据库\n",
    "- 标品信托成立规模统计\n",
    "\n",
    "## 功能说明\n",
    "\n",
    "1. **数据采集**：从用益信托网API获取信托产品列表\n",
    "2. **内容解析**：解析文章详情页，提取中文内容\n",
    "3. **数据存储**：将采集的数据存储到MySQL数据库\n",
    "4. **规模统计**：创建存储过程统计标品信托成立规模"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 1. 环境配置与依赖导入\n",
    "\n",
    "导入所需的库并加载配置文件。"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 环境配置与依赖导入\n",
    "import os\n",
    "import sys\n",
    "import json\n",
    "import re\n",
    "import requests\n",
    "from datetime import datetime, timedelta\n",
    "from time import sleep\n",
    "\n",
    "# 数据处理\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "\n",
    "# 数据库\n",
    "import sqlalchemy\n",
    "from sqlalchemy import text\n",
    "import pymysql\n",
    "\n",
    "# 网页解析\n",
    "from bs4 import BeautifulSoup\n",
    "\n",
    "# 导入配置\n",
    "from config import (\n",
    "    get_db_connection_string,\n",
    "    USETRUST_API_URL,\n",
    "    USETRUST_DETAIL_URL,\n",
    "    get_request_headers,\n",
    "    REQUEST_TIMEOUT,\n",
    "    DEFAULT_PAGE_SIZE,\n",
    "    DEFAULT_PARENT_ID\n",
    ")\n",
    "\n",
    "print(\"依赖导入完成\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. 数据库连接配置\n",
    "\n",
    "配置数据库连接，用于存储采集的信托数据。"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 数据库连接配置\n",
    "def create_db_engine():\n",
    "    \"\"\"创建数据库连接引擎\"\"\"\n",
    "    connection_string = get_db_connection_string()\n",
    "    engine = sqlalchemy.create_engine(\n",
    "        connection_string,\n",
    "        poolclass=sqlalchemy.pool.NullPool,\n",
    "        pool_recycle=3600\n",
    "    )\n",
    "    return engine\n",
    "\n",
    "# 创建数据库连接\n",
    "db_engine = create_db_engine()\n",
    "print(\"数据库连接创建成功\")\n",
    "\n",
    "# 测试连接\n",
    "try:\n",
    "    with db_engine.connect() as conn:\n",
    "        result = conn.execute(text(\"SELECT 1\"))\n",
    "        print(\"数据库连接测试成功\")\n",
    "except Exception as e:\n",
    "    print(f\"数据库连接测试失败: {e}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. 核心功能函数\n",
    "\n",
    "定义用益信托数据采集的核心功能函数。"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 核心功能函数\n",
    "\n",
    "class YongsTrustCollector:\n",
    "    \"\"\"用益信托数据采集器\"\"\"\n",
    "    \n",
    "    def __init__(self):\n",
    "        \"\"\"初始化采集器\"\"\"\n",
    "        self.api_url = USETRUST_API_URL\n",
    "        self.detail_url = USETRUST_DETAIL_URL\n",
    "        self.headers = get_request_headers()\n",
    "        self.timeout = REQUEST_TIMEOUT\n",
    "        \n",
    "    def fetch_article_list(self, page_index=1, page_size=None, parent_id=None):\n",
    "        \"\"\"获取文章列表\n",
    "        \n",
    "        Args:\n",
    "            page_index: 页码\n",
    "            page_size: 每页数量\n",
    "            parent_id: 分类ID\n",
    "            \n",
    "        Returns:\n",
    "            pd.DataFrame: 文章列表数据\n",
    "        \"\"\"\n",
    "        if page_size is None:\n",
    "            page_size = DEFAULT_PAGE_SIZE\n",
    "        if parent_id is None:\n",
    "            parent_id = DEFAULT_PARENT_ID\n",
    "            \n",
    "        post_data = {\n",
    "            'pageIndex': str(page_index),\n",
    "            'mode': 'ListArticle',\n",
    "            'pageSize': str(page_size),\n",
    "            'parentId': parent_id\n",
    "        }\n",
    "        \n",
    "        try:\n",
    "            response = requests.post(\n",
    "                self.api_url,\n",
    "                headers=self.headers,\n",
    "                data=post_data,\n",
    "                timeout=self.timeout\n",
    "            )\n",
    "            \n",
    "            # 修复JSON格式\n",
    "            text = response.text\n",
    "            corrected_text = text.replace(\n",
    "                f\"pageIndex:{page_index}\",\n",
    "                f'\"pageIndex\":\"{page_index}\"'\n",
    "            )\n",
    "            \n",
    "            data = json.loads(corrected_text)\n",
    "            df = pd.DataFrame(data['result'])\n",
    "            return df\n",
    "            \n",
    "        except Exception as e:\n",
    "            print(f\"获取文章列表失败: {e}\")\n",
    "            return pd.DataFrame()\n",
    "            \n",
    "    @staticmethod\n",
    "    def extract_chinese_content(text):\n    "        \"\"\"从网页文本中提取中文内容\n",
    "        \n",
    "        Args:\n",
    "            text: 网页文本\n",
    "            \n",
    "        Returns:\n",
    "            str: 提取的中文内容\n",
    "        \"\"\"\n",
    "        pattern = re.compile(r'责任编辑(.*?)打印文章', re.S)\n",
    "        match = pattern.search(text)\n",
    "        \n",
    "        if match:\n",
    "            content_between = match.group(1)\n",
    "            # 匹配中文字符、数字和标点\n",
    "            chinese_pattern = re.compile(r\"[\\u4e00-\\u9fa50-9.，。%-、]+\")\n",
    "            filtered_chars = chinese_pattern.findall(content_between)\n",
    "            result = ''.join(filtered_chars)\n",
    "            return result\n",
    "        else:\n",
    "            return \"未找到符合条件的内容\"\n",
    "            \n",
    "    def fetch_article_detail(self, article_id):\n",
    "        \"\"\"获取文章详情\n",
    "        \n",
    "        Args:\n",
    "            article_id: 文章ID\n",
    "            \n",
    "        Returns:\n",
    "            str: 文章内容\n",
    "        \"\"\"\n",
    "        url = f\"{self.detail_url}?i={article_id}\"\n",
    "        \n",
    "        try:\n",
    "            response = requests.get(url, timeout=self.timeout)\n",
    "            if response.status_code == 200:\n",
    "                soup = BeautifulSoup(response.text, 'html.parser')\n",
    "                all_text = soup.get_text()\n",
    "                chinese_content = self.extract_chinese_content(all_text)\n",
    "                return chinese_content\n",
    "            else:\n",
    "                print(f\"请求失败，状态码: {response.status_code}\")\n",
    "                return \"\"\n",
    "        except Exception as e:\n",
    "            print(f\"获取文章详情失败 [{article_id}]: {e}\")\n",
    "            return \"\"\n",
    "\n",
    "print(\"YongsTrustCollector类定义完成\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. 数据存储功能\n",
    "\n",
    "将采集的数据存储到MySQL数据库。"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 数据存储功能\n",
    "\n",
    "def insert_article_to_db(conn, row):\n",
    "    \"\"\"插入文章到数据库\n",
    "    \n",
    "    Args:\n",
    "        conn: 数据库连接\n",
    "        row: 文章数据行\n",
    "    \"\"\"\n",
    "    sql = \"\"\"\n",
    "    INSERT IGNORE INTO 用益信托 \n",
    "    (ROWID, C_ID, CAT_ID, C_TITLE, C_SUBTITLE, C_SUMMARY, C_SOURCE, C_IMAGEURL, C_ADDTIME)\n",
    "    VALUES (:ROWID, :C_ID, :CAT_ID, :C_TITLE, :C_SUBTITLE, :C_SUMMARY, :C_SOURCE, :C_IMAGEURL, :C_ADDTIME)\n",
    "    \"\"\"\n",
    "    \n",
    "    params = {\n",
    "        \"ROWID\": row['ROWID'],\n",
    "        \"C_ID\": row['C_ID'],\n",
    "        \"CAT_ID\": row['CAT_ID'],\n",
    "        \"C_TITLE\": row['C_TITLE'],\n",
    "        \"C_SUBTITLE\": row['C_SUBTITLE'],\n",
    "        \"C_SUMMARY\": row['C_SUMMARY'],\n",
    "        \"C_SOURCE\": row['C_SOURCE'],\n",
    "        \"C_IMAGEURL\": row['C_IMAGEURL'],\n",
    "        \"C_ADDTIME\": row['C_ADDTIME']\n",
    "    }\n",
    "    \n",
    "    conn.execute(text(sql), params)\n",
    "    \n",
    "def update_article_content(conn, article_id, content):\n",
    "    \"\"\"更新文章内容\n",
    "    \n",
    "    Args:\n",
    "        conn: 数据库连接\n",
    "        article_id: 文章ID\n",
    "        content: 文章内容\n",
    "    \"\"\"\n",
    "    sql = \"\"\"UPDATE 用益信托 SET content = :content WHERE C_ID = :cid\"\"\"\n",
    "    params = {\"content\": content, \"cid\": article_id}\n",
    "    conn.execute(text(sql), params)\n",
    "\n",
    "print(\"数据存储函数定义完成\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. 存储过程创建\n",
    "\n",
    "创建用于统计标品信托成立规模的存储过程。"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 存储过程创建\n",
    "\n",
    "def create_scale_procedure(conn):\n",
    "    \"\"\"创建标品信托成立规模统计存储过程\n",
    "    \n",
    "    Args:\n",
    "        conn: 数据库连接\n",
    "    \"\"\"\n",
    "    # 删除已存在的存储过程\n",
    "    drop_sql = \"DROP PROCEDURE IF EXISTS FindMatchingRecords\"\n",
    "    conn.execute(text(drop_sql))\n",
    "    \n",
    "    # 创建新存储过程\n",
    "    create_sql = \"\"\"\n",
    "    CREATE PROCEDURE FindMatchingRecords()\n",
    "    BEGIN\n",
    "        DECLARE done INT DEFAULT 0;\n",
    "        DECLARE content_text TEXT;\n",
    "        DECLARE addtime DATETIME;\n",
    "        DECLARE cursor_content CURSOR FOR SELECT C_ADDTIME, content FROM 用益信托;\n",
    "        DECLARE CONTINUE HANDLER FOR NOT FOUND SET done = 1;\n",
    "\n",
    "        DROP TEMPORARY TABLE IF EXISTS temp_用益信托;\n",
    "        CREATE TEMPORARY TABLE temp_用益信托 (\n",
    "            C_ADDTIME DATETIME,\n",
    "            成立规模 DECIMAL(10,2),\n",
    "            紧邻前50字符 VARCHAR(50)\n",
    "        );\n",
    "\n",
    "        OPEN cursor_content;\n",
    "\n",
    "        read_loop: LOOP\n",
    "            FETCH cursor_content INTO addtime, content_text;\n",
    "            IF done THEN\n",
    "                LEAVE read_loop;\n",
    "            END IF;\n",
    "\n",
    "            SET @pos = 1;\n",
    "            WHILE @pos > 0 DO\n",
    "                SET @pos = LOCATE('成立规模', content_text, @pos);\n",
    "                IF @pos > 0 THEN\n",
    "                    SET @start_pos = GREATEST(1, @pos - 50);\n",
    "                    SET @sub_content = SUBSTRING(content_text, @start_pos, 50);\n",
    "                    IF @sub_content LIKE '%标品信托%' THEN\n",
    "                        SET @scale_text = SUBSTRING(content_text, @pos + CHAR_LENGTH('成立规模'), 10);\n",
    "                        SET @scale_value = CAST(SUBSTRING_INDEX(@scale_text, '亿', 1) AS DECIMAL(10,2));\n",
    "                        INSERT INTO temp_用益信托 (C_ADDTIME, 成立规模, 紧邻前50字符)\n",
    "                        VALUES (addtime, @scale_value, @sub_content);\n",
    "                    END IF;\n",
    "                    SET @pos = @pos + 1;\n",
    "                END IF;\n",
    "            END WHILE;\n",
    "        END LOOP;\n",
    "\n",
    "        CLOSE cursor_content;\n",
    "    END;\n",
    "    \"\"\"\n",
    "    conn.execute(text(create_sql))\n",
    "    print(\"存储过程创建成功\")\n",
    "\n",
    "def execute_scale_procedure(conn):\n",
    "    \"\"\"执行存储过程并更新规模数据\n",
    "    \n",
    "    Args:\n",
    "        conn: 数据库连接\n",
    "    \"\"\"\n",
    "    # 执行存储过程\n",
    "    conn.execute(text(\"CALL FindMatchingRecords()\"))\n",
    "    \n",
    "    # 更新标品信托成立规模\n",
    "    update_sql = \"\"\"\n",
    "    UPDATE 用益信托 A\n",
    "    JOIN (\n",
    "        SELECT C_ADDTIME as dt, MAX(成立规模) as 成立规模 \n",
    "        FROM temp_用益信托 \n",
    "        WHERE 成立规模 > 0\n",
    "        GROUP BY C_ADDTIME\n",
    "    ) B\n",
    "    ON A.C_ADDTIME = B.dt\n",
    "    SET A.标品信托成立规模 = B.成立规模;\n",
    "    \"\"\"\n",
    "    conn.execute(text(update_sql))\n",
    "    print(\"标品信托成立规模更新完成\")\n",
    "\n",
    "print(\"存储过程函数定义完成\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. 数据采集执行\n",
    "\n",
    "执行完整的数据采集流程。"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 数据采集执行\n",
    "\n",
    "def collect_trust_data(page_count=1):\n",
    "    \"\"\"采集信托数据\n",
    "    \n",
    "    Args:\n",
    "        page_count: 要采集的页数\n",
    "    \"\"\"\n",
    "    collector = YongsTrustCollector()\n",
    "    \n",
    "    for page in range(1, page_count + 1):\n",
    "        print(f\"\\n正在采集第 {page} 页...\")\n",
    "        \n",
    "        # 获取文章列表\n",
    "        df = collector.fetch_article_list(page_index=page)\n",
    "        \n",
    "        if df.empty:\n",
    "            print(f\"第 {page} 页没有数据\")\n",
    "            continue\n",
    "            \n",
    "        print(f\"获取到 {len(df)} 篇文章\")\n",
    "        \n",
    "        # 处理每篇文章\n",
    "        with db_engine.begin() as conn:\n",
    "            for index, row in df.iterrows():\n",
    "                try:\n",
    "                    # 插入文章基本信息\n",
    "                    insert_article_to_db(conn, row)\n",
    "                    \n",
    "                    # 获取并更新文章内容\n",
    "                    content = collector.fetch_article_detail(row['C_ID'])\n",
    "                    if content:\n",
    "                        update_article_content(conn, row['C_ID'], content)\n",
    "                        \n",
    "                    print(f\"  处理完成: {index + 1}/{len(df)} - {row['C_TITLE'][:20]}...\")\n",
    "                    \n",
    "                    # 添加延迟避免请求过快\n",
    "                    sleep(0.5)\n",
    "                    \n",
    "                except Exception as e:\n",
    "                    print(f\"  处理失败 [{row['C_ID']}]: {e}\")\n",
    "                    \n",
    "    print(f\"\\n数据采集完成，共处理 {page_count} 页\")\n",
    "\n",
    "print(\"数据采集函数定义完成\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 7. 主程序执行\n",
    "\n",
    "执行完整的数据采集和统计流程。"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 主程序执行\n",
    "\n",
    "def main():\n",
    "    \"\"\"主执行函数\"\"\"\n",
    "    print(\"=\" * 50)\n",
    "    print(\"T64-用益信托 数据采集任务开始\")\n",
    "    print(f\"执行时间: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\")\n",
    "    print(\"=\" * 50)\n",
    "    \n",
    "    # 1. 数据采集\n",
    "    print(\"\\n[1/3] 采集信托数据...\")\n",
    "    collect_trust_data(page_count=1)  # 可根据需要调整页数\n",
    "    \n",
    "    # 2. 创建存储过程\n",
    "    print(\"\\n[2/3] 创建存储过程...\")\n",
    "    try:\n",
    "        with db_engine.begin() as conn:\n",
    "            create_scale_procedure(conn)\n",
    "    except Exception as e:\n",
    "        print(f\"创建存储过程失败: {e}\")\n",
    "        \n",
    "    # 3. 执行存储过程\n",
    "    print(\"\\n[3/3] 统计标品信托成立规模...\")\n",
    "    try:\n",
    "        with db_engine.begin() as conn:\n",
    "            execute_scale_procedure(conn)\n",
    "    except Exception as e:\n",
    "        print(f\"执行存储过程失败: {e}\")\n",
    "        \n",
    "    print(\"\\n\" + \"=\" * 50)\n",
    "    print(\"T64-用益信托 数据采集任务完成\")\n",
    "    print(\"=\" * 50)\n",
    "\n",
    "# 执行主程序\n",
    "if __name__ == '__main__':\n",
    "    main()"
   ]
  },
