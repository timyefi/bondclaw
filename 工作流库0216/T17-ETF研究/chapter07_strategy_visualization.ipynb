    "                              nav_data: pd.DataFrame,\n",
    "                              unit_data: pd.DataFrame,\n",
    "                              start_date: str = None,\n",
    "                              end_date: str = None) -> dict:\n",
    "    \"\"\"Run complete ETF strategy analysis\n",
    "    \n",
    "    Args:\n",
    "        df: ETF base info DataFrame\n",
    "        nav_data: NAV data\n",
    "        unit_data: Unit data\n",
    "        start_date: Start date\n",
    "        end_date: End date\n",
    "        \n",
    "    Returns:\n",
    "        Dictionary with all analysis results\n",
    "    \"\"\"\n",
    "    logger.info(\"Starting ETF strategy analysis...\")\n",
    "    \n",
    "    results = {}\n",
    "    \n",
    "    # 1. Stock ETF Analysis\n",
    "    logger.info(\"Analyzing stock ETFs...\")\n",
    "    stock_result = generate_stock_etf_tracking_index_table(\n",
    "        df, nav_data, unit_data, start_date, end_date\n",
    "    )\n",
    "    results['stock_etf'] = stock_result\n",
    "    \n",
    "    # 2. Bond ETF Analysis\n",
    "    logger.info(\"Analyzing bond ETFs...\")\n",
    "    bond_result = generate_bond_etf_strategy_table(\n",
    "        df, nav_data, unit_data, start_date, end_date\n",
    "    )\n",
    "    results['bond_etf'] = bond_result\n",
    "    \n",
    "    # 3. Generate report\n",
    "    logger.info(\"Generating report...\")\n",
    "    report_path = generate_summary_report(results)\n",
    "    results['report_path'] = report_path\n",
    "    \n",
    "    logger.info(\"ETF strategy analysis completed.\")\n",
    "    \n",
    "    return results\n",
    "\n",
