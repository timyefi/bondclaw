    "def generate_bond_etf_strategy_table(df: pd.DataFrame,\n",
    "                                      nav_data: pd.DataFrame,\n",
    "                                      unit_data: pd.DataFrame,\n",
    "                                      start_date: str = None,\n",
    "                                      end_date: str = None) -> pd.DataFrame:\n",
    "    \"\"\"Generate bond ETF strategy analysis table\n",
    "    \n",
    "    Args:\n",
    "        df: ETF base info DataFrame\n",
    "        nav_data: NAV data\n",
    "        unit_data: Unit data\n",
    "        start_date: Start date\n",
    "        end_date: End date\n",
    "        \n",
    "    Returns:\n",
    "        Analysis results DataFrame\n",
    "    \"\"\"\n",
    "    # Filter bond ETFs\n",
    "    bond_df = df[df['INVEST_TYPE_FIRST'] == 'bond'].copy()\n",
    "    \n",
    "    if bond_df.empty:\n",
    "        return pd.DataFrame()\n",
    "    \n",
    "    results = []\n",
    "    \n",
    "    # Group by sector and duration\n",
    "    group_cols = ['SECTOR', 'DURATION']\n",
    "    \n",
    "    for _, group in bond_df.groupby(group_cols):\n",
    "        sector = group['SECTOR'].iloc[0]\n",
    "        duration = group['DURATION'].iloc[0]\n",
    "        \n",
    "        metrics = calculate_strategy_metrics(\n",
    "            group, nav_data, unit_data, start_date, end_date\n",
    "        )\n",
    "        \n",
    "        if metrics:\n",
    "            results.append({\n",
    "                'Sector': sector,\n",
    "                'Duration': duration,\n",
    "                'Fund Count': metrics['fund_count'],\n",
    "                'Total Size': f\"{group['UNIT_TOTAL'].sum() / 1e8:.2f}B\",\n",
    "                'Annual Return': f\"{metrics['annual_return']:.2f}%\",\n",
    "                'Max Drawdown': f\"{metrics['max_drawdown']:.2f}%\"\n",
    "            })\n",
    "    \n",
    "    return pd.DataFrame(results)\n",
    "\n",
    "print(\"Bond ETF analysis function defined\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 8. Report Generation"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def generate_summary_report(results: dict, output_dir: str = None) -> str:\n",
    "    \"\"\"Generate summary report\n",
    "    \n",
    "    Args:\n",
    "        results: Dictionary with analysis results\n",
    "        output_dir: Output directory\n",
    "        \n",
    "    Returns:\n",
    "        Report file path\n",
    "    \"\"\"\n",
    "    output_dir = output_dir or str(OUTPUT_DIR)\n",
    "    \n",
    "    report_lines = [\n",
    "        '# ETF Strategy Analysis Report',\n",
    "        '',\n",
    "        f'Generated: {datetime.datetime.now().strftime(\"%Y-%m-%d %H:%M:%S\")}',\n",
    "        '',\n",
    "        '## Summary Statistics',\n",
    "        ''\n",
    "    ]\n",
    "    \n",
    "    # Add summary statistics\n",
    "    for key, value in results.items():\n",
    "        if isinstance(value, pd.DataFrame) and not value.empty:\n",
    "            report_lines.append(f'### {key}')\n",
    "            report_lines.append('')\n",
    "            report_lines.append(value.to_markdown(index=False))\n",
    "            report_lines.append('')\n",
    "    \n",
    "    # Write report\n",
    "    report_content = '\\n'.join(report_lines)\n",
    "    report_path = os.path.join(output_dir, 'etf_analysis_report.md')\n",
    "    \n",
    "    with open(report_path, 'w', encoding='utf-8') as f:\n",
    "        f.write(report_content)\n",
    "    \n",
    "    logger.info(f\"Report saved to {report_path}\")\n",
    "    return report_path\n",
    "\n",
    "print(\"Report generation function defined\")"
   ]
  },
  {
   "cell_type": "markdown",
