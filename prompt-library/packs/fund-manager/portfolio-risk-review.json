{
  "id": "fund-manager-portfolio-risk-review-v1",
  "role": "fund-manager",
  "workflow": "portfolio-risk-review",
  "variant": "default",
  "required_skills": [
    "research-writing"
  ],
  "input_schema": {
    "type": "object",
    "required": [
      "review_date",
      "portfolio_status",
      "risk_signals"
    ],
    "properties": {
      "review_date": { "type": "string" },
      "portfolio_status": { "type": "string" },
      "risk_signals": { "type": "array", "items": { "type": "string" } }
    }
  },
  "prompt_template": "基于输入复核日期、组合状态和风险信号，生成一份组合风险复盘。要求拆分头寸、收益、回撤、风险暴露和下一步调整建议。",
  "output_format": "markdown",
  "sample_case": {
    "review_date": "2026-04-11",
    "portfolio_status": "中性偏防守",
    "risk_signals": ["利率上行", "信用分化"]
  },
  "qa_checklist": [
    "组合状态是否清楚",
    "风险暴露是否覆盖",
    "调整建议是否明确",
    "是否适合投委会复盘"
  ]
}
