  "core_functionality": {
    "main_features": [
      "收益率曲线构建：基于中债曲线数据，使用Hermite插值法计算任意期限的收益率",
      "多维度分类：支持城投/产业、公募/私募、永续/非永续等多种分类维度",
      "信用债利差计算：计算信用债相对于基准曲线的利差",
      "标准化收益率调整：将任意期限债券的收益率调整到标准期限"
    ],
    "algorithms": {
      "hermite_interpolation": {
        "name": "三次Hermite插值",
        "formula": "y(x) = y1*H1(t) + y2*H2(t) + d1*H3(t) + d2*H4(t)",
        "basis_functions": {
          "H1": "1 - 3t^2 + 2t^3",
          "H2": "3t^2 - 2t^3",
          "H3": "t - 2t^2 + t^3",
          "H4": "-t^2 + t^3"
        },
        "notes": "保持曲线光滑（导数连续），避免龙格现象"
      },
      "derivative_calculation": {
        "method": "中心差分",
        "formula": "d1 = (y2 - y11) / (2 * (x2 - x11))"
      },
      "standardized_yield": {
        "formula": "目标期限收益率 = 中债行权估值 + (目标期限曲线收益率 - 原期限曲线收益率)"
      }
    }
  },
