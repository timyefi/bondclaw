  "algorithms": {
    "rfy_premium": {
      "name": "RFY Premium",
      "description": "评级基准收益率溢价，衡量交易收益率相对评级的偏离",
      "formula": "交易收益率 - 评级基准收益率"
    },
    "herding_index": {
      "name": "Herding Index",
      "description": "羊群效应指数，基于LSV模型计算",
      "formula": "H = |p_i - p| - AF"
    },
    "duration_flow": {
      "name": "Duration of Net Flow",
      "description": "久期净流向，反映机构久期配置倾向",
      "formula": "买入加权久期 - 卖出加权久期"
    },
    "term_spread": {
      "name": "期限利差",
      "description": "10年期国债与1年期国债收益率之差",
      "formula": "10Y国债收益率 - 1Y国债收益率"
    },
    "credit_spread": {
      "name": "信用利差",
      "description": "AA+ 3Y中票与3Y国债收益率之差",
