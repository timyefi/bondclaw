    "## 5. Chart Visualization"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class ChartVisualizer:\n",
    "    \"\"\"Chart visualization for ETF analysis\"\"\"\n",
    "    \n",
    "    def __init__(self, output_dir: str = None):\n",
    "        self.output_dir = output_dir or str(PLOT_DIR)\n",
    "    \n",
    "    def plot_size_comparison(self, size_data: pd.DataFrame, \n",
    "                             title: str = 'ETF Size Comparison'):\n",
    "        \"\"\"Plot ETF size comparison bar chart\n",
    "        \n",
    "        Args:\n",
    "            size_data: DataFrame with size data\n",
    "            title: Chart title\n",
    "            \n",
    "        Returns:\n",
    "            Plotly Figure object\n",
    "        \"\"\"\n",
    "        fig = go.Figure()\n",
    "        \n",
    "        fig.add_trace(go.Bar(\n",
    "            x=size_data['category'],\n",
    "            y=size_data['size'],\n",
    "            text=size_data['size'].round(2),\n",
    "            textposition='auto',\n",
    "            marker_color='steelblue'\n",
    "        ))\n",
    "        \n",
    "        fig.update_layout(\n",
    "            title=title,\n",
    "            xaxis_title='Category',\n",
    "            yaxis_title='Size (Billion Yuan)',\n",
    "            template='plotly_white'\n",
    "        )\n",
    "        \n",
    "        return fig\n",
    "    \n",
    "    def plot_performance_comparison(self, perf_data: pd.DataFrame,\n",
    "                                     title: str = 'Strategy Performance'):\n",
    "        \"\"\"Plot performance comparison\n",
    "        \n",
    "        Args:\n",
    "            perf_data: DataFrame with performance metrics\n",
    "            title: Chart title\n",
    "            \n",
    "        Returns:\n",
    "            Plotly Figure object\n",
    "        \"\"\"\n",
    "        fig = make_subplots(\n",
    "            rows=2, cols=2,\n",
    "            subplot_titles=('Annual Return', 'Volatility', \n",
    "                           'Max Drawdown', 'Sharpe Ratio')\n",
    "        )\n",
    "        \n",
    "        metrics = ['annual_return', 'volatility', 'max_drawdown', 'sharpe_ratio']\n",
    "        colors = ['green', 'orange', 'red', 'blue']\n",
    "        \n",
    "        for idx, (metric, color) in enumerate(zip(metrics, colors)):\n",
    "            row = idx // 2 + 1\n",
    "            col = idx % 2 + 1\n",
    "            \n",
    "            fig.add_trace(\n",
    "                go.Bar(x=perf_data['strategy'], y=perf_data[metric],\n",
    "                       marker_color=color, showlegend=False),\n",
    "                row=row, col=col\n",
    "            )\n",
    "        \n",
    "        fig.update_layout(\n",
    "            title=title,\n",
    "            height=800,\n",
    "            template='plotly_white'\n",
    "        )\n",
    "        \n",
    "        return fig\n",
    "    \n",
    "    def plot_historical_trend(self, trend_data: pd.DataFrame,\n",
    "                               title: str = 'Historical Trend'):\n",
    "        \"\"\"Plot historical trend line chart\n",
    "        \n",
    "        Args:\n",
    "            trend_data: DataFrame with trend data\n",
    "            title: Chart title\n",
    "            \n",
    "        Returns:\n",
    "            Plotly Figure object\n",
    "        \"\"\"\n",
    "        fig = go.Figure()\n",
    "        \n",
    "        for col in trend_data.columns:\n",
    "            if col != 'date':\n",
    "                fig.add_trace(go.Scatter(\n",
    "                    x=trend_data['date'],\n",
    "                    y=trend_data[col],\n",
    "                    mode='lines',\n",
    "                    name=col\n",
    "                ))\n",
    "        \n",
    "        fig.update_layout(\n",
    "            title=title,\n",
    "            xaxis_title='Date',\n",
    "            yaxis_title='Value',\n",
    "            template='plotly_white',\n",
    "            legend=dict(orientation='h', yanchor='bottom', y=1.02)\n",
    "        )\n",
    "        \n",
    "        return fig\n",
    "    \n",
    "    def save_figure(self, fig: go.Figure, filename: str):\n",
    "        \"\"\"Save figure to file\n",
    "        \n",
    "        Args:\n",
    "            fig: Plotly Figure object\n",
    "            filename: Output filename\n",
    "        \"\"\"\n",
    "        output_path = os.path.join(self.output_dir, f'{filename}.html')\n",
    "        fig.write_html(output_path)\n",
    "        logger.info(f\"Figure saved to {output_path}\")\n",
    "\n",
    "# Initialize chart visualizer\n",
    "chart_viz = ChartVisualizer()\n",
    "print(\"Chart visualizer initialized\")"
   ]
  },
