{
  "project_id": "T39",
  "project_name": "成交数据",
  "project_path": "G:\\我的云端硬盘\\workspace\\projects\\工作库0216\\T39-成交数据",
  "exploration_date": "2026-02-16",
  "status": "completed",

  "project_overview": {
    "description": "成交数据项目专注于收集、处理和分析债券市场的成交数据，包括成交量、成交金额、成交价格、成交结构等，为市场流动性分析、交易策略制定和投资决策提供数据支持。",
    "data_source": "评级狗API (ratingdog.cn)",
    "core_function": "债券成交数据采集与分析系统"
  },

  "directory_structure": {
    "root": "T39-成交数据/",
    "files": [
      "config.py - 配置模块",
      "README.md - 项目说明",
      "requirements.txt - Python依赖",
      "report.json - 重构报告"
    ],
    "notebooks": [
      "01-环境配置.ipynb",
      "02-数据采集.ipynb",
      "03-数据处理.ipynb",
      "04-流动性分析.ipynb",
      "05-结构分析.ipynb",
      "06-可视化.ipynb",
      "07-报告生成.ipynb",
      "重构.ipynb"
    ],
    "subdirectories": [
      "src/ - 原始代码文件",
      "data/ - 数据文件(空)",
      "output/ - 输出目录(空)",
      "assets/ - 资源文件"
    ]
  },

  "configuration": {
    "config_file": "config.py",
    "classes": [
      {
        "name": "DatabaseConfig",
        "description": "数据库配置类",
        "attributes": ["mysql_host", "mysql_port", "mysql_user", "mysql_password", "mysql_database_yq", "mysql_database_bond", "pg_host", "pg_port", "pg_user", "pg_password", "pg_database"]
      },
      {
        "name": "RatingDogAPIConfig",
        "description": "评级狗API配置类",
        "attributes": ["login_url", "trade_data_url", "username", "phone_code", "password", "tenant_id", "timeout", "max_result_count", "max_retries", "retry_interval"]
      },
      {
        "name": "TradeDataConfig",
        "description": "成交数据配置类",
        "attributes": ["data_sources", "time_frames", "aggregation_levels", "liquidity_thresholds", "volume_thresholds", "price_min", "price_max", "amount_min"]
      },
      {
        "name": "ProcessConfig",
        "description": "处理流程配置类",
        "attributes": ["date_step", "start_date", "end_date", "incremental_update", "output_table", "date_source_table", "dedup_fields"]
      }
    ],
    "environment_variables": [
      "MYSQL_HOST",
      "MYSQL_PORT",
      "MYSQL_USER",
      "MYSQL_PASSWORD",
      "MYSQL_DATABASE_YQ",
      "MYSQL_DATABASE_BOND",
      "PG_HOST",
      "PG_PORT",
      "PG_USER",
      "PG_PASSWORD",
      "PG_DATABASE",
      "RATINGDOG_USERNAME",
      "RATINGDOG_PHONE_CODE",
      "RATINGDOG_PASSWORD"
    ]
  },

  "dependencies": {
    "core": ["pandas>=1.5.0", "numpy>=1.21.0"],
    "database": ["sqlalchemy>=1.4.0", "pymysql>=1.0.0", "psycopg2-binary>=2.9.0"],
    "network": ["requests>=2.28.0"],
    "visualization": ["matplotlib>=3.5.0"],
    "utilities": ["chardet>=5.0.0", "python-dateutil>=2.8.0"],
    "jupyter": ["jupyter>=1.0.0", "ipykernel>=6.0.0"]
  },

  "api_endpoints": {
    "login": {
      "url": "https://auth.ratingdog.cn/api/TokenAuth/Authenticate",
      "method": "POST",
      "purpose": "获取访问令牌"
    },
    "trade_data": {
      "url": "https://host.ratingdog.cn/api/services/app/Bond/QueryTradedHistoricalOfFrontDeskTenants",
      "method": "POST",
      "purpose": "查询成交历史数据",
      "pagination": "每页最多150条记录"
    }
  },

  "database_tables": {
    "source": {
      "table": "bond.marketinfo_abs",
      "purpose": "ABS市场信息表，获取日期范围"
    },
    "target": [
      {
        "table": "yq.cjqb",
        "purpose": "全部成交数据表"
      },
      {
        "table": "yq.cj",
        "purpose": "中介成交数据表"
      }
    ]
  },

  "modules": {
    "01_环境配置": {
      "file": "01-环境配置.ipynb",
      "features": ["依赖包安装指南", "环境变量配置说明", "数据库连接测试", "评级狗API连接测试", "环境配置检查总结"]
    },
    "02_数据采集": {
      "file": "02-数据采集.ipynb",
      "classes": [
        {"name": "RatingDogAuthenticator", "description": "API认证器，管理登录和令牌"},
        {"name": "TradeDataCollector", "description": "数据采集器，分页获取成交数据"}
      ],
      "features": ["分页数据获取", "重试机制", "增量更新支持"]
    },
    "03_数据处理": {
      "file": "03-数据处理.ipynb",
      "classes": [
        {"name": "TradeDataLoader", "description": "数据加载器"},
        {"name": "TradeDataCleaner", "description": "数据清洗器"},
        {"name": "TradeDataTransformer", "description": "数据转换器"},
        {"name": "TradeDataAggregator", "description": "数据聚合器"},
        {"name": "TradeDataPipeline", "description": "处理流水线"}
      ],
      "features": ["按日期聚合", "按债券聚合", "按评级聚合", "数据质量报告"]
    },
    "04_流动性分析": {
      "file": "04-流动性分析.ipynb",
      "class": "LiquidityAnalyzer",
      "methods": ["calculate_trade_frequency", "calculate_volume_metrics", "calculate_price_volatility", "calculate_yield_spread"],
      "features": ["交易频率指标", "成交量指标", "价格波动率", "综合流动性评分", "流动性分类(高/中/低)", "流动性趋势分析"]
    },
    "05_结构分析": {
      "file": "05-结构分析.ipynb",
      "class": "StructureAnalyzer",
      "methods": ["analyze_by_field", "analyze_industry_distribution", "analyze_rating_distribution", "analyze_daily_pattern", "analyze_weekday_pattern"],
      "features": ["行业分布分析", "评级分布分析", "每日交易模式", "周内交易模式", "成交金额规模分布"]
    },
    "06_可视化": {
      "file": "06-可视化.ipynb",
      "charts": ["plot_daily_amount_trend", "plot_industry_distribution", "plot_rating_distribution", "plot_weekday_pattern", "plot_amount_histogram", "create_dashboard"],
      "features": ["成交金额走势图", "行业分布图", "评级分布饼图", "周内交易模式图", "成交金额分布直方图", "综合仪表板"]
    },
    "07_报告生成": {
      "file": "07-报告生成.ipynb",
      "class": "TradeDataReportGenerator",
      "methods": ["generate_overview_section", "generate_liquidity_section", "generate_structure_section", "generate_top_bonds_section", "generate_full_report"],
      "features": ["数据概览报告", "流动性分析报告", "结构分析报告", "JSON/Markdown导出"]
    }
  },

  "data_flow": {
    "description": "数据库查询日期范围 -> 评级狗API登录 -> 分页获取成交数据 -> 存储数据库 -> 数据处理 -> 分析 -> 可视化 -> 报告生成",
    "steps": [
      "1. 从bond.marketinfo_abs获取待采集日期",
      "2. 评级狗API认证获取accessToken",
      "3. 分页获取成交数据items[]",
      "4. 存储到yq.cjqb表",
      "5. 数据清洗、转换、聚合",
      "6. 流动性分析和结构分析",
      "7. 生成可视化图表",
      "8. 导出JSON/Markdown报告"
    ]
  },

  "key_parameters": {
    "liquidity_thresholds": {
      "high": 0.7,
      "medium": 0.4,
      "low": 0.0
    },
    "volume_thresholds": {
      "large": 100000000,
      "medium": 10000000,
      "small": 1000000
    },
    "price_range": {
      "min": 0.0,
      "max": 200.0
    },
    "api_settings": {
      "timeout": 30,
      "max_result_count": 150,
      "max_retries": 5,
      "retry_interval": 1.0
    }
  },

  "source_files": {
    "path": "src/",
    "files": [
      "YY成交全部.ipynb - 原始全部成交数据采集代码",
      "YY成交中介.ipynb - 原始中介成交数据采集代码"
    ]
  },

