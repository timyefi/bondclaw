{
  "id": "trader-liquidity-warning-v1",
  "role": "trader",
  "workflow": "liquidity-warning",
  "variant": "default",
  "required_skills": [
    "research-writing"
  ],
  "input_schema": {
    "type": "object",
    "required": [
      "date",
      "liquidity_warning",
      "affected_list"
    ],
    "properties": {
      "date": { "type": "string" },
      "liquidity_warning": { "type": "string" },
      "affected_list": { "type": "array", "items": { "type": "string" } }
    }
  },
  "prompt_template": "基于输入日期、流动性预警和受影响标的，生成一份交易流动性警报。要求说明预警级别、受影响方向、执行建议和需要避免的操作。",
  "output_format": "markdown",
  "sample_case": {
    "date": "2026-04-11",
    "liquidity_warning": "下午资金趋紧",
    "affected_list": ["债券A", "转债B"]
  },
  "qa_checklist": [
    "预警级别是否明确",
    "影响标的是否完整",
    "执行建议是否可操作",
    "是否适合盘中提醒"
  ]
}
