    "## 3. Table Configuration"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class TableTheme(Enum):\n",
    "    \"\"\"Table theme options\"\"\"\n",
    "    CLASSIC = 'classic'\n",
    "    MODERN = 'modern'\n",
    "    MINIMAL = 'minimal'\n",
    "\n",
    "class TableStyle(Enum):\n",
    "    \"\"\"Table style options\"\"\"\n",
    "    DEFAULT = 'default'\n",
    "    COMPACT = 'compact'\n",
    "    DETAILED = 'detailed'\n",
    "\n",
    "class TableLayout(Enum):\n",
    "    \"\"\"Table layout options\"\"\"\n",
    "    STANDARD = 'standard'\n",
    "    WIDE = 'wide'\n",
    "    NARROW = 'narrow'\n",
    "\n",
    "@dataclass\n",
    "class TableConfig:\n",
    "    \"\"\"Table configuration\"\"\"\n",
    "    title: str\n",
    "    theme: TableTheme = TableTheme.CLASSIC\n",
    "    style: TableStyle = TableStyle.DEFAULT\n",
    "    layout: TableLayout = TableLayout.STANDARD\n",
    "    data_source: str = 'Data Source: Research, WIND, THS'\n",
    "    show_index: bool = False\n",
    "    column_formats: Dict[str, str] = None\n",
    "    highlight_columns: List[str] = None"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Table Generator Class"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "class TableGenerator:\n",
    "    \"\"\"Table generation for ETF analysis\"\"\"\n",
    "    \n",
    "    def __init__(self, output_dir: str = None):\n",
    "        \"\"\"Initialize table generator\n",
    "        \n",
    "        Args:\n",
    "            output_dir: Output directory path\n",
    "        \"\"\"\n",
    "        self.output_dir = output_dir or str(PLOT_DIR)\n",
    "        self.dpi = OUTPUT_CONFIG.figure_dpi\n",
    "    \n",
    "    def generate_table(self, df: pd.DataFrame, config: TableConfig,\n",
    "                       output_prefix: str = 'table') -> str:\n",
    "        \"\"\"Generate table image\n",
    "        \n",
    "        Args:\n",
    "            df: DataFrame to render\n",
    "            config: Table configuration\n",
    "            output_prefix: Output filename prefix\n",
    "            \n",
    "        Returns:\n",
    "            Output file path\n",
    "        \"\"\"\n",
    "        # Prepare data\n",
    "        if config.show_index:\n",
    "            df = df.reset_index()\n",
    "        \n",
    "        # Calculate figure size\n",
    "        n_rows = len(df) + 2  # header + data + source\n",
    "        n_cols = len(df.columns)\n",
    "        \n",
    "        fig_width = max(10, n_cols * 2)\n",
    "        fig_height = max(6, n_rows * 0.5)\n",
    "        \n",
    "        # Create figure\n",
n",
    "        fig, ax = plt.subplots(figsize=(fig_width, fig_height))\n",
    "        ax.axis('off')\n",
    "        \n",
    "        # Create table\n",
    "        table = ax.table(\n",
    "            cellText=df.values,\n",
    "            colLabels=df.columns,\n",
    "            loc='center',\n",
    "            cellLoc='center'\n",
    "        )\n",
    "        \n",
    "        # Style table\n",
    "        table.auto_set_font_size(False)\n",
    "        table.set_fontsize(10)\n",
    "        table.scale(1.2, 1.5)\n",
    "        \n",
    "        # Apply theme colors\n",
    "        if config.theme == TableTheme.CLASSIC:\n",
    "            header_color = '#4472C4'\n",
    "            row_colors = ['#D6DCE4', '#FFFFFF']\n",
    "        elif config.theme == TableTheme.MODERN:\n",
    "            header_color = '#2E86AB'\n",
    "            row_colors = ['#E8F4F8', '#FFFFFF']\n",
    "        else:\n",
    "            header_color = '#333333'\n",
    "            row_colors = ['#F5F5F5', '#FFFFFF']\n",
    "        \n",
    "        # Style header\n",
    "        for j in range(n_cols):\n",
    "            cell = table[(0, j)]\n",
    "            cell.set_facecolor(header_color)\n",
    "            cell.set_text_props(color='white', fontweight='bold')\n",
    "        \n",
    "        # Style data rows\n",
    "        for i in range(1, n_rows - 1):\n",
    "            for j in range(n_cols):\n",
    "                cell = table[(i, j)]\n",
    "                cell.set_facecolor(row_colors[(i-1) % 2])\n",
    "        \n",
    "        # Add title\n",
    "        plt.title(config.title, fontsize=14, fontweight='bold', pad=20)\n",
    "        \n",
    "        # Add data source\n",
    "        plt.figtext(0.5, 0.02, config.data_source, \n",
    "                   ha='center', fontsize=8, style='italic')\n",
    "        \n",
    "        # Save figure\n",
    "        output_path = os.path.join(self.output_dir, f'{output_prefix}.png')\n",
    "        plt.savefig(output_path, dpi=self.dpi, bbox_inches='tight', \n",
    "                   facecolor='white', edgecolor='none')\n",
    "        plt.close()\n",
    "        \n",
    "        logger.info(f\"Table saved to {output_path}\")\n",
    "        return output_path\n",
    "    \n",
    "    def generate_multi_size(self, df: pd.DataFrame, config: TableConfig,\n",
    "                            output_prefix: str) -> Dict[str, str]:\n",
    "        \"\"\"Generate table in multiple sizes\n",
    "        \n",
    "        Args:\n",
    "            df: DataFrame to render\n",
    "            config: Table configuration\n",
    "            output_prefix: Output filename prefix\n",
    "            \n",
    "        Returns:\n",
    "            Dictionary of size -> file path\n",
    "        \"\"\"\n",
    "        sizes = {\n",
    "            'small': (800, 600),\n",
    "            'medium': (1200, 900),\n",
    "            'large': (1600, 1200)\n",
    "        }\n",
    "        \n",
    "        results = {}\n",
    "        original_dpi = self.dpi\n",
    "        \n",
    "        for size_name, (width, height) in sizes.items():\n",
    "            self.dpi = 100  # Reset DPI\n",
    "            output_path = self.generate_table(\n",
    "                df, config, f'{output_prefix}_{size_name}'\n",
    "            )\n",
    "            results[size_name] = output_path\n",
    "        \n",
    "        self.dpi = original_dpi\n",
    "        return results\n",
    "\n",
    "# Initialize table generator\n",
    "table_generator = TableGenerator()\n",
    "print(\"Table generator initialized\")"
   ]
  },
